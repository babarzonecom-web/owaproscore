function EndGameModal({ game, onConfirm, onCancel }) {
  const [reason,   setReason]   = useState("normal"); 
  const [endInn,   setEndInn]   = useState(game.inning);
  const [endHalf,  setEndHalf]  = useState(game.half);
  const [note,     setNote]     = useState("");

  // 投手成績チェック
  const allPitchers = [...(game.awayPitchers||[]), ...(game.homePitchers||[])].filter(p=>p&&p.name);
  const initPR = {};
  allPitchers.forEach(p=>{ initPR[p.name]={win:false,lose:false,save:false,hold:false,bs:false}; });
  const [pitcherResults, setPitcherResults] = useState(initPR);
  const togglePR = (name, key) => {
    setPitcherResults(pr=>{
      const cur = pr[name]||{};
      // 勝敗はどちらか一方のみ
      if(key==="win"||key==="lose"){
        return {...pr,[name]:{...cur,win:false,lose:false,[key]:!cur[key]}};
      }
      return {...pr,[name]:{...cur,[key]:!cur[key]}};
    });
  };

  const awayTotal = calcTotal(game.awayScore);
  const homeTotal = calcTotal(game.homeScore);
  const winner = awayTotal > homeTotal ? game.awayTeam
               : homeTotal > awayTotal ? game.homeTeam : "引き分け";

  const COLD_REASONS = [
    {code:"cold",   label:"コールドゲーム",  desc:"規定回数前に得点差で試合終了"},
    {code:"mercy",  label:"コールド成立",    desc:"マーシールール適用"},
    {code:"normal", label:"正式試合終了",    desc:"9回（延長）終了"},
    {code:"weather",label:"降雨コールド",    desc:"天候・グラウンド不良"},
    {code:"dark",   label:"日没コールド",    desc:"照明なし・日没"},
    {code:"other",  label:"その他",          desc:""},
  ];

  const allInnings = Array.from({length:15},(_,i)=>i+1);

  return (
    React.createElement('div', { style: S.overlay, onClick: onCancel,}
      , React.createElement('div', { style: {...S.mBox,maxWidth:400}, onClick: e=>e.stopPropagation(),}
        , React.createElement('div', { style: {...S.mt,marginBottom:4,fontSize:18},}, "⚾ 試合終了" )

        
        , React.createElement('div', { style: {background:"#0a1628",borderRadius:10,padding:"10px 14px",
          marginBottom:16,textAlign:"center"},}
          , React.createElement('div', { style: {fontFamily:"'Bebas Neue',sans-serif",fontSize:32,letterSpacing:2},}
            , React.createElement('span', { style: {color:"#fbbf24"},}, awayTotal)
            , React.createElement('span', { style: {color:"#334155",margin:"0 8px",fontSize:20},}, "—")
            , React.createElement('span', { style: {color:"#7dd3fc"},}, homeTotal)
          )
          , React.createElement('div', { style: {fontSize:12,color:"#94a3b8",marginTop:2},}
            , awayTotal!==homeTotal
              ? React.createElement(React.Fragment, null, React.createElement('span', { style: {color:"#fbbf24",fontWeight:700},}, winner), " の勝利" )
              : React.createElement('span', { style: {color:"#94a3b8"},}, "引き分け")
          )
        )

        
        , React.createElement('div', { style: {marginBottom:14},}
          , React.createElement('div', { style: {fontSize:12,color:"#7db8e8",marginBottom:8,fontWeight:700},}, "終了理由")
          , React.createElement('div', { style: {display:"flex",flexDirection:"column",gap:6},}
            , COLD_REASONS.map(r=>(
              React.createElement('button', { key: r.code, onClick: ()=>setReason(r.code), style: {
                background:reason===r.code?"#1d4ed833":"transparent",
                border:`1.5px solid ${reason===r.code?"#3b82f6":"#1e3a5f"}`,
                borderRadius:8,padding:"8px 12px",cursor:"pointer",textAlign:"left",
                display:"flex",gap:10,alignItems:"center",
              },}
                , React.createElement('span', { style: {fontSize:16,width:20,textAlign:"center",flexShrink:0},}
                  , reason===r.code?"●":"○"
                )
                , React.createElement('div', null
                  , React.createElement('div', { style: {fontSize:13,fontWeight:700,
                    color:reason===r.code?"#7dd3fc":"#e2e8f0"},}, r.label)
                  , r.desc&&React.createElement('div', { style: {fontSize:10,color:"#64748b"},}, r.desc)
                )
              )
            ))
          )
        )

        
        , reason!=="normal"&&(
          React.createElement('div', { style: {marginBottom:14},}
            , React.createElement('div', { style: {fontSize:12,color:"#7db8e8",marginBottom:8,fontWeight:700},}, "終了イニング")
            , React.createElement('div', { style: {display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"},}
              , React.createElement('select', { value: endInn, onChange: e=>setEndInn(Number(e.target.value)),
                style: {...S.si,cursor:"pointer"},}
                , allInnings.map(i=>React.createElement('option', { key: i, value: i,}, i, "回"))
              )
              , React.createElement('div', { style: {display:"flex",gap:6},}
                , ["top","bottom"].map(h=>(
                  React.createElement('button', { key: h, onClick: ()=>setEndHalf(h), style: {
                    padding:"5px 12px",borderRadius:7,cursor:"pointer",fontSize:12,fontWeight:700,
                    background:endHalf===h?"#1d4ed833":"transparent",
                    border:`1.5px solid ${endHalf===h?"#3b82f6":"#2a4a7a"}`,
                    color:endHalf===h?"#7dd3fc":"#7db8e8",
                  },}, h==="top"?"表":"裏")
                ))
              )
            )
          )
        )

        
        , React.createElement('div', { style: {marginBottom:16},}
          , React.createElement('div', { style: {fontSize:12,color:"#7db8e8",marginBottom:6,fontWeight:700},}, "メモ（任意）")
          , React.createElement('input', { value: note, onChange: e=>setNote(e.target.value),
            placeholder: "例: 5回コールド、雨天中止など" ,
            style: {...S.si,width:"100%",padding:"7px 10px",fontSize:13},})
        )

        
        , allPitchers.length > 0 && React.createElement('div', {style:{marginBottom:16}}
          , React.createElement('div', {style:{fontSize:12,color:"#7db8e8",marginBottom:8,fontWeight:700}}, "⚾ 投手成績")
          , React.createElement('div', {style:{fontSize:11,color:"#64748b",marginBottom:8}}, "勝・負・セーブ・ホールドを該当する投手にチェックしてください")
          , allPitchers.map(p=>React.createElement('div', {key:p.name,
              style:{display:"flex",alignItems:"center",gap:6,padding:"6px 10px",
                background:"#0a1628",borderRadius:7,marginBottom:5,border:"1px solid #1e3a5f",flexWrap:"wrap"}}
              , React.createElement('span', {style:{fontSize:13,fontWeight:700,color:"#e2e8f0",minWidth:60}}, p.name)
              , [["win","勝","#4ade80"],["lose","負","#f87171"],["save","S","#fbbf24"],["hold","H","#60a5fa"],["bs","BS","#fb923c"]].map(([key,label,color])=>
                  React.createElement('button', {key, onClick:()=>togglePR(p.name,key),
                    style:{padding:"3px 10px",borderRadius:12,fontSize:12,fontWeight:700,cursor:"pointer",
                      background:(pitcherResults[p.name]||{})[key]?color+"33":"transparent",
                      border:`1.5px solid ${(pitcherResults[p.name]||{})[key]?color:"#1e3a5f"}`,
                      color:(pitcherResults[p.name]||{})[key]?color:"#475569"}}, label))
            ))
        )

        , React.createElement('button', { onClick: ()=>onConfirm(reason, reason==="normal"?null:endInn, note, pitcherResults),
          style: {...sBt("#dc2626"),width:"100%",padding:"12px",fontSize:15,fontWeight:700,marginBottom:6},}, "⚾ この内容で試合終了"

        )
        , React.createElement('button', { onClick: onCancel, style: S.cBtn,}, "キャンセル")
      )
    )
  );
}
function PitcherPicker({ members, teams, currentTeamName, onSelect }) {
  const [open, setOpen] = useState(false);
  const btnRef = React.useRef(null);
  const [style, setStyle] = useState({});

  const handleOpen = () => {
    if(btnRef.current){
      const r = btnRef.current.getBoundingClientRect();
      const below = window.innerHeight - r.bottom;
      const popH = 280;
      setStyle({
        position:"fixed",
        left: Math.min(r.left, window.innerWidth-200),
        top: below>popH ? r.bottom+2 : r.top-popH-4,
        zIndex:9999, background:"#0f2040",
        border:"1px solid #2a4a7a", borderRadius:10, padding:8,
        display:"flex", flexDirection:"column", gap:4, width:192,
        maxHeight:280, overflowY:"auto",
        boxShadow:"0 8px 24px rgba(0,0,0,.8)",
      });
    }
    setOpen(o=>!o);
  };

  const groups = (teams||[]).map(t=>({
    name: t.name,
    ms: (t.members||[]).map(m=>typeof m==="string"?m:(m.name||"")).filter(Boolean),
  })).filter(g=>g.ms.length>0);
  const flat = groups.length===0 ? members : null;

  return (
    React.createElement('div', null
      , React.createElement('button', { ref: btnRef, onClick: handleOpen,
        style: {background:"transparent",border:"1px solid #2a4a7a",borderRadius:4,
          color:"#64748b",fontSize:9,padding:"1px 4px",cursor:"pointer"}}, "▼")
      , open&&(React.createElement(React.Fragment, null
        , React.createElement('div', { style: {position:"fixed",inset:0,zIndex:9998}, onClick: ()=>setOpen(false),})
        , React.createElement('div', { style: style,}
          , flat ? (
            React.createElement(React.Fragment, null
              , React.createElement('div', { style: {fontSize:10,color:"#475569",marginBottom:2,paddingLeft:2}}, "メンバーから選択")
              , flat.map(n=>(
                React.createElement('button', { key: n, onClick: ()=>{onSelect(n);setOpen(false);},
                  style: {background:"#0d1f35",border:"1px solid #1e3a5f",borderRadius:6,
                    color:"#e2e8f0",fontSize:12,fontWeight:600,padding:"5px 8px",
                    cursor:"pointer",textAlign:"left"}}
                  , n
                )
              ))
            )
          ) : (
            groups.map((g,gi)=>(
              React.createElement(React.Fragment, { key: g.name }
                , React.createElement('div', { style: {
                    fontSize:10, fontWeight:700, padding:"4px 4px 2px",
                    color: g.name===currentTeamName ? "#7dd3fc" : "#64748b",
                    borderTop: gi>0?"1px solid #1e3a5f":"none", marginTop: gi>0?4:0,
                  }}, g.name===currentTeamName ? "⭐ "+g.name : g.name)
                , g.ms.map(n=>(
                  React.createElement('button', { key: n, onClick: ()=>{onSelect(n);setOpen(false);},
                    style: {background:"#0d1f35",border:"1px solid #1e3a5f",borderRadius:6,
                      color:"#e2e8f0",fontSize:12,fontWeight:600,padding:"5px 8px",
                      cursor:"pointer",textAlign:"left"}}
                    , n
                  )
                ))
              )
            ))
          )
        )
      ))
    )
  );
}
const POS_OPTS = ["投","捕","一","二","三","遊","左","中","右","D","代"];

function PosSelector({ value, onChange }) {
  const [open, setOpen] = useState(false);
  const [popupStyle, setPopupStyle] = useState({});
  const btnRef = React.useRef(null);

  const handleOpen = () => {
    if (btnRef.current) {
      const rect = btnRef.current.getBoundingClientRect();
      const spaceBelow = window.innerHeight - rect.bottom;
      const popupH = 130; 
      
      const openUp = spaceBelow < popupH;
      setPopupStyle({
        position: "fixed",
        left: Math.min(rect.left, window.innerWidth - 186),
        top: openUp ? rect.top - popupH - 4 : rect.bottom + 4,
        zIndex: 9999,
        background: "linear-gradient(135deg,#0f2040,#0a1628)",
        border: "1px solid #2a4a7a",
        borderRadius: 10,
        padding: 8,
        display: "flex",
        flexWrap: "wrap",
        gap: 5,
        width: 178,
        boxShadow: "0 8px 32px rgba(0,0,0,.85)",
      });
    }
    setOpen(o => !o);
  };

  return (
    React.createElement('div', { style: {position:"relative"},}
      , React.createElement('button', { ref: btnRef, onClick: handleOpen,
        style: {background:"transparent",border:"1px solid #2a4a7a",
          borderRadius:5,color:"#7dd3fc",fontSize:11,fontWeight:700,
          padding:"4px 6px",cursor:"pointer",minWidth:32,textAlign:"center",
          touchAction:"manipulation"},}
        , value||"—"
      )
      , open&&(React.createElement(React.Fragment, null
        , React.createElement('div', { style: {position:"fixed",inset:0,zIndex:9998}, onClick: ()=>setOpen(false),})
        , React.createElement('div', { style: popupStyle,}
          , POS_OPTS.map(p=>(
            React.createElement('button', { key: p, onClick: ()=>{ onChange(p); setOpen(false); },
              style: {width:46,height:38,borderRadius:7,cursor:"pointer",fontWeight:700,fontSize:13,
                background:value===p?"#1d4ed8":"#0d1f35",
                border:`1.5px solid ${value===p?"#3b82f6":"#1e3a5f"}`,
                color:value===p?"#fff":"#7db8e8",
                touchAction:"manipulation"},}
              , p
            )
          ))
        )
      ))
    )
  );
}
const POSITIONS = ["投","捕","一","二","三","遊","左","中","右","D","代"];

function SubstituteModal({ player, team, game, pidx, teams, onConfirm, onCancel }) {
  const [newName, setNewName] = useState("");
  const [newPos,  setNewPos]  = useState(_optionalChain([player, 'optionalAccess', _82 => _82.pos])||"");
  const [mode, setMode]       = useState("name"); 
  const [reason, setReason]   = useState("");

  
  const side = team; 
  const teamName = game[side+"Team"];
  const regTeam = (teams||[]).find(t=>t.name===teamName);
  const regMembers = (_optionalChain([regTeam, 'optionalAccess', _83 => _83.members])||[]).map(m=>typeof m==="string"?m:(m.name||"")).filter(Boolean);
  
  const lineup = game[side+"Lineup"]||[];
  const usedNames = new Set(lineup.map(p=>p.name));
  const candidates = regMembers.filter(n=>!usedNames.has(n));

  return (
    React.createElement('div', { style: S.overlay, onClick: onCancel,}
      , React.createElement('div', { style: {...S.mBox,maxWidth:360,maxHeight:"90vh",overflowY:"auto"}, onClick: e=>e.stopPropagation(),}
        , React.createElement('div', { style: {...S.mt,marginBottom:4},}, "🔄 守備交代 / ポジション変更"   )
        , React.createElement('div', { style: {fontSize:11,color:"#94a3b8",marginBottom:14},}
          , pidx+1, "番 " , React.createElement('span', { style: {color:"#fbbf24",fontWeight:700},}, _optionalChain([player, 'optionalAccess', _84 => _84.name])), "（", _optionalChain([player, 'optionalAccess', _85 => _85.pos])||"-", "）と交代"
        )

        
        , React.createElement('div', { style: {display:"flex",gap:6,marginBottom:14},}
          , [["name","選手交代"],["pos","ポジション変更のみ"]].map(([m,lbl])=>(
            React.createElement('button', { key: m, onClick: ()=>setMode(m), style: {
              flex:1,padding:"6px",borderRadius:8,cursor:"pointer",fontSize:12,fontWeight:700,
              background:mode===m?"#1d4ed833":"transparent",
              border:`1.5px solid ${mode===m?"#3b82f6":"#2a4a7a"}`,
              color:mode===m?"#7dd3fc":"#7db8e8",
            },}, lbl)
          ))
        )

        , mode==="name"&&(React.createElement(React.Fragment, null
          
          , candidates.length>0&&(
            React.createElement('div', { style: {marginBottom:12},}
              , React.createElement('div', { style: {fontSize:11,color:"#7db8e8",marginBottom:6,fontWeight:700},}, "登録メンバーから選ぶ")
              , React.createElement('div', { style: {display:"flex",flexWrap:"wrap",gap:5},}
                , candidates.map(n=>(
                  React.createElement('button', { key: n, onClick: ()=>setNewName(n),
                    style: {padding:"5px 10px",borderRadius:7,cursor:"pointer",fontSize:12,fontWeight:700,
                      background:newName===n?"#1d4ed8":"#0d1f35",
                      border:`1.5px solid ${newName===n?"#3b82f6":"#1e3a5f"}`,
                      color:newName===n?"#fff":"#e2e8f0"},}
                    , n
                  )
                ))
              )
            )
          )
          , React.createElement('div', { style: {marginBottom:14},}
            , React.createElement('div', { style: {fontSize:11,color:"#7db8e8",marginBottom:5,fontWeight:700},}, "直接入力")
            , React.createElement('input', { value: newName, onChange: e=>setNewName(e.target.value),
              placeholder: "選手名を入力",
              style: {...S.si,width:"100%",padding:"8px 10px",fontSize:14},})
          )
        ))

        
        , React.createElement('div', { style: {marginBottom:12},}
          , React.createElement('div', { style: {fontSize:11,color:"#7db8e8",marginBottom:6,fontWeight:700},}, "ポジション")
          , React.createElement('div', { style: {display:"flex",flexWrap:"wrap",gap:5},}
            , POSITIONS.map(pos=>(
              React.createElement('button', { key: pos, onClick: ()=>setNewPos(pos), style: {
                padding:"5px 10px",borderRadius:7,cursor:"pointer",fontSize:12,fontWeight:700,
                background:newPos===pos?"#1d4ed833":"transparent",
                border:`1.5px solid ${newPos===pos?"#3b82f6":"#2a4a7a"}`,
                color:newPos===pos?"#7dd3fc":"#7db8e8",
              },}, pos)
            ))
          )
        )

        
        , mode==="name"&&(
          React.createElement('div', { style: {marginBottom:14},}
            , React.createElement('div', { style: {fontSize:11,color:"#7db8e8",marginBottom:5,fontWeight:700},}, "交代理由（任意）")
            , React.createElement('div', { style: {display:"flex",flexWrap:"wrap",gap:5,marginBottom:6},}
              , ["代打","代走","守備固め"].map(r=>(
                React.createElement('button', { key: r, onClick: ()=>setReason(r===reason?"":r),
                  style: {padding:"4px 10px",borderRadius:6,cursor:"pointer",fontSize:11,
                    background:reason===r?"#1d4ed833":"transparent",
                    border:`1px solid ${reason===r?"#3b82f6":"#2a4a7a"}`,
                    color:reason===r?"#7dd3fc":"#64748b"},}
                  , r
                )
              ))
            )
            , React.createElement('input', { value: reason, onChange: e=>setReason(e.target.value),
              placeholder: "その他の理由",
              style: {...S.si,width:"100%",padding:"5px 8px",fontSize:12},})
          )
        )

        , React.createElement('button', {
          onClick: ()=>{ if(newName.trim()||mode==="pos") onConfirm(mode==="pos"?_optionalChain([player, 'optionalAccess', _86 => _86.name])||"":newName.trim(), newPos||_optionalChain([player, 'optionalAccess', _87 => _87.pos])||"", reason); },
          disabled: mode==="name"&&!newName.trim(),
          style: {...sBt("#16a34a"),width:"100%",padding:"11px",fontSize:14,fontWeight:700,marginBottom:6,
            opacity:mode==="name"&&!newName.trim()?0.4:1},}, "✅ "
           , mode==="name"?`${_optionalChain([player, 'optionalAccess', _88 => _88.name])} → ${newName||"?"}`:`ポジション → ${newPos||"?"}`, " で確定"
        )
        , React.createElement('button', { onClick: onCancel, style: S.cBtn,}, "キャンセル")
      )
    )
  );
}
const sBt = (color, outline=false) => ({
  background:outline?"transparent":color,
  border:`1.5px solid ${color}`,
  borderRadius:7, color:outline?color:"#fff",
  padding:"5px 12px", cursor:"pointer", fontSize:12, fontWeight:700,
});

const S = {
  root:{
    minHeight:"100vh",
    background:"linear-gradient(160deg,#080f1e 0%,#0d1a2e 50%,#060c18 100%)",
    fontFamily:"'Noto Sans JP',sans-serif", color:"#e2e8f0", paddingBottom:60,
  },
  header:{
    background:"linear-gradient(180deg,#0f2040,#0a1628)",
    borderBottom:"1px solid #1e3a5f",
    padding:"12px 16px 10px",
    position:"sticky", top:0, zIndex:90,
  },
  hRow:{
    maxWidth:860, margin:"0 auto",
    display:"flex", alignItems:"center", gap:12, marginBottom:10,
  },
  liveRow:{
    maxWidth:860, margin:"0 auto",
    display:"flex", alignItems:"center", gap:14, flexWrap:"wrap",
  },
  nav:{
    background:"#080f1e", borderBottom:"1px solid #1e3a5f",
    display:"flex", maxWidth:860, margin:"0 auto",
    overflowX:"auto", padding:"0 12px",
  },
  card:{
    background:"linear-gradient(135deg,#0d1f35,#0a1828)",
    border:"1px solid #1e3a5f", borderRadius:12,
    padding:16, marginBottom:14,
  },
  ct:{ fontSize:14, fontWeight:700, color:"#7dd3fc", marginBottom:12 },
  si:{
    background:"#1e3a5f", border:"1px solid #2a4a7a", borderRadius:6,
    color:"#e2e8f0", padding:"5px 8px", fontSize:13, outline:"none",
  },
  table:{ width:"100%", borderCollapse:"collapse", minWidth:440 },
  th:{
    padding:"7px 4px", textAlign:"center", fontSize:11, color:"#64748b",
    fontWeight:700, borderBottom:"1px solid #1e3a5f", whiteSpace:"nowrap",
  },
  td:{ padding:"6px 4px", fontSize:13, borderBottom:"1px solid #0f2040" },
  overlay:{
    position:"fixed", inset:0, background:"rgba(0,0,0,.88)",
    display:"flex", alignItems:"center", justifyContent:"center",
    zIndex:200, padding:16,
  },
  mBox:{
    background:"linear-gradient(135deg,#0f2040,#0a1628)",
    border:"1px solid #2a4a7a", borderRadius:16,
    padding:20, maxWidth:400, width:"100%", maxHeight:"92vh", overflowY:"auto",
  },
  mt:{ fontSize:15, fontWeight:700, color:"#7dd3fc" },
  backBtn:{
    background:"transparent", border:"none", color:"#7db8e8",
    cursor:"pointer", fontSize:20, padding:"0 4px", lineHeight:1,
  },
  cBtn:{
    marginTop:8, width:"100%", background:"transparent",
    border:"1px solid #2a4a7a", borderRadius:8, color:"#7db8e8",
    padding:"8px", cursor:"pointer", fontSize:13,
  },
  toast:{
    position:"fixed", bottom:70, left:"50%", transform:"translateX(-50%)",
    background:"#16a34a", color:"#fff", padding:"8px 22px", borderRadius:20,
    fontSize:13, fontWeight:700, zIndex:300, pointerEvents:"none",
    boxShadow:"0 4px 20px rgba(0,0,0,.5)",
  },
};

try {
  ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App));
} catch(e) {
  document.getElementById('root').innerHTML = '<div style="color:white;padding:20px;font-size:14px"><h2>起動エラー</h2><pre style="white-space:pre-wrap;font-size:11px">' + (e.stack||e.message) + '</pre></div>';
}
  

try {
  ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App));
} catch(e) {
  document.getElementById('root').innerHTML = '<div style="color:white;padding:20px"><h2>エラー</h2><pre style="font-size:11px;white-space:pre-wrap;color:#f87171">' + (e.stack||e.message) + '</pre></div>';
}
</script>
</body>
