        )

        
        , teams.length>1&&(
          React.createElement('div', { style: {marginBottom:14},}
            , React.createElement('div', { style: {fontSize:12,color:"#7db8e8",marginBottom:8,fontWeight:700},}, "チームを選択")
            , React.createElement('div', { style: {display:"flex",flexWrap:"wrap",gap:6},}
              , teams.map(t=>(
                React.createElement('button', { key: t.id, onClick: ()=>{ setSelTeam(t); setAssignments({}); setActiveSlot(null); },
                  style: {padding:"6px 14px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:12,
                    background:_optionalChain([selTeam, 'optionalAccess', _73 => _73.id])===t.id?"#1d4ed833":"#0d1f35",
                    border:`1.5px solid ${_optionalChain([selTeam, 'optionalAccess', _74 => _74.id])===t.id?"#3b82f6":"#1e3a5f"}`,
                    color:_optionalChain([selTeam, 'optionalAccess', _75 => _75.id])===t.id?"#7dd3fc":"#94a3b8"},}
                  , t.name
                  , React.createElement('span', { style: {fontSize:10,color:"#475569",marginLeft:4},}, "(", _optionalChain([t, 'access', _76 => _76.members, 'optionalAccess', _77 => _77.length])||0, "名)")
                )
              ))
            )
          )
        )

        , selTeam&&(React.createElement(React.Fragment, null
          
          , React.createElement('div', { style: {display:"flex",alignItems:"center",gap:10,marginBottom:10,
            background:"#0a1628",borderRadius:8,padding:"8px 12px"},}
            , React.createElement('span', { style: {fontSize:12,color:"#7db8e8",fontWeight:700},}, "打順数")
            , React.createElement('button', { onClick: removeSlot, disabled: slotCount<=1,
              style: {width:28,height:28,borderRadius:6,border:"1px solid #2a4a7a",
                background:"#0d1f35",color:"#7db8e8",fontSize:16,cursor:"pointer",
                opacity:slotCount<=1?0.3:1},}, "－")
            , React.createElement('span', { style: {fontSize:16,fontWeight:700,color:"#e2e8f0",minWidth:28,textAlign:"center"},}, slotCount)
            , React.createElement('button', { onClick: addSlot, disabled: slotCount>=15,
              style: {width:28,height:28,borderRadius:6,border:"1px solid #2a4a7a",
                background:"#0d1f35",color:"#7db8e8",fontSize:16,cursor:"pointer",
                opacity:slotCount>=15?0.3:1},}, "＋")
            , React.createElement('span', { style: {fontSize:11,color:"#475569",marginLeft:4},}
              , assignedCount, "/", slotCount, " 人割り当て済み"
            )
          )

          , React.createElement('div', { style: {display:"flex",gap:12,marginBottom:4},}
            
            , React.createElement('div', { style: {flex:1},}
              , React.createElement('div', { style: {fontSize:11,color:"#7db8e8",marginBottom:6,fontWeight:700},}, "打順")
              , React.createElement('div', { style: {display:"flex",flexDirection:"column",gap:4},}
                , lineupSlots.map(i=>{
                  const assigned = assignments[i];
                  const isActive = activeSlot===i;
                  return (
                    React.createElement('div', { key: i, onClick: ()=>setActiveSlot(isActive?null:i),
                      style: {display:"flex",alignItems:"center",gap:6,cursor:"pointer",
                        background:isActive?"#1d3a6e":(assigned?"#0d2a1a":"#0d1f35"),
                        border:`1.5px solid ${isActive?"#3b82f6":assigned?"#22c55e":"#1e3a5f"}`,
                        borderRadius:8,padding:"6px 10px",transition:"all 0.1s"},}
                      , React.createElement('span', { style: {fontSize:11,color:"#475569",minWidth:18,textAlign:"center",fontWeight:700},}, i+1)
                      , assigned ? (
                        React.createElement(React.Fragment, null
