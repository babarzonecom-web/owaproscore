                , selTeam.name
              )
              , React.createElement('div', { style: {display:"flex",flexDirection:"column",gap:4},}
                , members.map((m,mi)=>{
                  const name = typeof m==="string"?m:(m.name||"");
                  if(!name) return null;
                  const isUsed = usedNames.has(name);
                  return (
                    React.createElement('button', { key: mi,
                      onClick: ()=>{ if(activeSlot!==null) assign(activeSlot, name); },
                      disabled: isUsed&&!(assignments[activeSlot]===name),
                      style: {padding:"6px 8px",borderRadius:7,cursor:activeSlot!==null&&!isUsed?"pointer":"default",
                        background:isUsed?"#0d2a1a":"#0d1f35",
                        border:`1.5px solid ${isUsed?"#22c55e":"#1e3a5f"}`,
                        color:isUsed?"#4ade80":"#e2e8f0",
                        fontSize:12,fontWeight:600,textAlign:"left",
                        opacity:activeSlot===null?0.7:isUsed?0.5:1},}
                      , name
                      , isUsed&&React.createElement('span', { style: {fontSize:9,color:"#22c55e",marginLeft:4},}, "✓")
                    )
                  );
                })
              )
            )
          )

          , React.createElement('div', { style: {fontSize:11,color:"#64748b",marginBottom:12,textAlign:"center"},}, "打順スロットをタップ → 右のメンバーを選択"

          )
        ))

        , React.createElement('button', { onClick: handleApply, disabled: !selTeam||assignedCount===0,
          style: {...sBt("#16a34a"),width:"100%",padding:"11px",fontSize:14,fontWeight:700,
            marginBottom:6,opacity:(selTeam&&assignedCount>0)?1:0.35},}, "✅ "
           , assignedCount, "名のスタメンをセット"
        )
        , React.createElement('button', { onClick: onCancel, style: S.cBtn,}, "キャンセル")
      )
    )
  );
}

