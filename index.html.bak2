          React.createElement('button', {
            onClick: ()=>{ if(!isECode) setShowErrPicker(v=>!v); },
            style: {...sBt(adjErrorPos?"#7f1d1d":"#1e3a5f"), width:"100%", padding:"8px", fontSize:12,
              border:`1px dashed ${adjErrorPos?"#f87171":"#2a4a7a"}`, marginBottom: showErrPicker?8:0,
              opacity: isECode ? 0.6 : 1, cursor: isECode ? "default" : "pointer"},
          }, adjErrorPos ? `🔴 エラー: ${adjErrorPos}` : "🔴 エラーを追加（任意）")
          , !isECode && showErrPicker && React.createElement('div', {style:{background:"#0a1628",borderRadius:8,padding:10,border:"1px solid #1e3a5f"}},
            React.createElement('div', {style:{fontSize:11,color:"#94a3b8",marginBottom:8}}, "エラーをつけるポジションを選択"),
            React.createElement('div', {style:{display:"flex",flexWrap:"wrap",gap:6,marginBottom:6}},
              ["投","捕","一","二","三","遊","左","中","右"].map(pos => {
                const defLineup = defTeamLineup||[];
                const posMap = {};
                defLineup.forEach(p=>{ if(p.pos) posMap[p.pos]=p.name; });
                const pname = posMap[pos];
                return React.createElement('button', {
                  key: pos,
                  onClick: ()=>{ setAdjErrorPos(adjErrorPos===pos?null:pos); },
                  style: {
                    padding:"6px 10px", borderRadius:7, cursor:"pointer", fontSize:12, fontWeight:700,
                    background: adjErrorPos===pos?"#7f1d1d":"#0d1f35",
                    border:`1.5px solid ${adjErrorPos===pos?"#f87171":"#1e3a5f"}`,
                    color: adjErrorPos===pos?"#f87171":"#e2e8f0",
                    display:"flex", flexDirection:"column", alignItems:"center", gap:2,
                  }
                }, pos, pname&&React.createElement('span',{style:{fontSize:9,color:"#94a3b8"}},pname));
              })
            )
            , React.createElement('button', {
              onClick:()=>{setAdjErrorPos(null);setShowErrPicker(false);},
              style:{fontSize:11,color:"#64748b",background:"transparent",border:"none",cursor:"pointer",padding:"4px 0"}
            }, "エラーなし（クリア）")
          )
        )
        , React.createElement('button', { onClick: onCancel, style: S.cBtn,}, "キャンセル")
      )
    )
  );
}
const norm   = (e) => (typeof e==="object"&&e!==null)?e:{code:e};
const eShort = (e) => { const n=norm(e); return (_optionalChain([rOf, 'call', _2 => _2(n.code), 'optionalAccess', _3 => _3.short])||n.code)+(n.dir?`(${n.dir})`:""); };
const eRuns  = (list) => list.reduce((s,e)=>s+(norm(e).runs||0),0);
const toList = (ab,inn) => Array.isArray(ab[inn])?ab[inn]:(ab[inn]?[ab[inn]]:[]);

const makePlayer  = (i) => ({ id:i, name:`選手${i}`, pos:"", atBats:{}, rbi:0, sb:0, cs:0 });
const makePitcher = (i) => ({ id:i, name:`投手${i}`, ip:0, h:0, er:0, bb:0, k:0,
  
  autoIp:0, autoH:0, autoEr:0, autoBb:0, autoK:0,
  manualOverride:false, 
});
const makeLineup  = (n=DEFAULT_PLAYERS) => Array.from({length:n},(_,i)=>makePlayer(i+1));
const makePitchers= () => Array.from({length:5},(_,i)=>makePitcher(i+1));
const emptyScore  = (n=9) => Object.fromEntries(Array.from({length:n},(_,i)=>i+1).map(i=>[i,""]));
const calcTotal   = (s) => Object.values(s).reduce((a,v)=>a+(parseInt(v)||0),0);

const recomputeScores = (g) => {
  const aScore={...g.awayScore}, hScore={...g.homeScore};
  const _inns = Array.from({length:g.innings||9},(_,i)=>i+1);
  _inns.forEach(inn=>{
    let ar=0, hr=0, aHas=false, hHas=false;
    g.awayLineup.forEach(p=>toList(p.atBats,inn).forEach(e=>{ ar+=norm(e).runs||0; aHas=true; }));
    g.homeLineup.forEach(p=>toList(p.atBats,inn).forEach(e=>{ hr+=norm(e).runs||0; hHas=true; }));
    // 打席がある回だけスコアをセット（まだ攻撃していない回は""のまま）
    if(aHas) aScore[inn]=ar;
    if(hHas) hScore[inn]=hr;
  });
  return {awayScore:aScore, homeScore:hScore};
};

const computeOneStats = (p) => {
  let ab=0,h=0,hr=0,bb=0,hbp=0,k=0,tb=0,r=0,sac=0,sf=0;
  const atBatsObj = p.atBats || {};
  Object.values(atBatsObj).flat().forEach(e=>{
    const ne=norm(e); const code=ne.code; if(!code) return;
    if(!NOAB_CODES.has(code)) ab++;
    if(HIT_CODES.has(code)){h++;tb+=code==="H1"?1:code==="H2"?2:code==="H3"?3:4;}
    if(code==="HR") hr++;
    if(code==="BB") bb++;
    if(code==="HBP") hbp++;
    if(code==="K"||code==="KL"||code==="KW") k++;
    if(code==="SAC") sac++;
    if(code==="SF")  sf++;
  });
  r += (p.run||0);  // HR・盗塁・WP等すべての得点はp.runに集約
  const pa = ab + bb + hbp + sac + sf;
  const slg = ab>0 ? (tb/ab) : 0;
  const obp = (ab+bb+hbp)>0 ? ((h+bb+hbp)/(ab+bb+hbp)) : 0;
  const ops = obp + slg;
  const fmtAvg = v => v>0 ? v.toFixed(3).replace(/^0/,"") : ".---";
  return {...p,_pa:pa,_ab:ab,_h:h,_hr:hr,_bb:bb,_hbp:hbp,_k:k,_tb:tb,_r:r,
    _avg:ab>0?(h/ab).toFixed(3).replace(/^0/,""):".---",
    _slg:ab>0?fmtAvg(slg):".---",
    _obp:(ab+bb+hbp)>0?fmtAvg(obp):".---",
    _ops:ops>0?ops.toFixed(3).replace(/^0/,""):".---",
  };
};

const computeStats = (players) => {
  const rows = [];
  players.forEach(p => {
    // _subOuts配列（旧_subOut単体も吸収）から過去選手を先に追加
    const legacySubOut = p._subOut && !p._subOuts ? [p._subOut] : [];
    const subOuts = [...legacySubOut, ...(p._subOuts || [])];
    subOuts.forEach((prev, idx) => {
      const nextName = idx < subOuts.length-1 ? subOuts[idx+1].name : p.name;
      rows.push(computeOneStats({
        ...prev,
        id: (p.id||p.name) + "_subout_" + idx,
        order: p.order,
        _subOutLabel: true,
        _nextName: nextName,
      }));
    });
    // 現在の選手
    rows.push(computeOneStats({
      ...p,
      _subOut: null,
      _subOuts: null,
      _isSub: subOuts.length > 0,
      _prevName: subOuts.length > 0 ? subOuts[subOuts.length-1].name : null,
    }));
  });
  return rows;
};
const computePitcherStats = (g) => {
  const result = { away:[], home:[] };

  ["away","home"].forEach(defTeam=>{
    const offTeam = defTeam==="away" ? "home" : "away";
    const pitchers = g[defTeam+"Pitchers"];
    const pitcherLog = g[defTeam+"PitcherLog"]||[];
    const lineup = g[offTeam+"Lineup"];

    
    
    
    const currentPIdx = g[defTeam+"PitcherIdx"]||0;

    
    const OUT_CODES_FOR_IP = new Set(["K","KL","GO","FO","LO","FF","SAC","SF"]);
    const OUT_CODES = OUT_CODES_FOR_IP;
    const allAtBats = []; 
    const _pitInns = Array.from({length:g.innings||9},(_,i)=>i+1);
    _pitInns.forEach(inn=>{
      ["top","bottom"].forEach(half=>{
        
        const battingTeam = half==="top" ? "away" : "home";
        if(battingTeam !== offTeam) return;
        // このイニング・ハーフの累積アウト数を打席順に付与
        let outsInHalf = 0;
        lineup.forEach((p,pi)=>{
          toList(p.atBats,inn).forEach((e,ei)=>{
            const ne = norm(e);
            const outsAtAb = outsInHalf;
            allAtBats.push({inning:inn, half, playerIdx:pi, entryIdx:ei, entry:ne, outsAtAb});
            // この打席でアウトが増えた数を加算
            if(OUT_CODES_FOR_IP.has(ne.code)) outsInHalf++;
            if(ne.code==="DP") outsInHalf++;
          });
        });
      });
    });

    
    const stats = pitchers.map(p=>({...p, autoIp:0, autoH:0, autoEr:0, autoBb:0, autoK:0, _outsGot:0}));

    
    
    // 先発投手（idx:0）のエントリを必ず1回表頭に補完する
    // pitcherLogが空 or 最初のエントリが1回表より後の場合に対応
    const starterEntry = {pitcherIdx:0, fromInning:1, fromHalf:"top", outsAtStart:0};
    const rawLog = pitcherLog.length>0 ? pitcherLog : [];
    // 先発エントリが既にあるか確認
    const hasStarter = rawLog.some(l=>l.fromInning===1 && l.fromHalf==="top" && l.outsAtStart===0);
    const log = hasStarter ? rawLog : [starterEntry, ...rawLog];

    allAtBats.forEach(ab=>{
      let activePIdx = log[0].pitcherIdx;
      for(let i=0;i<log.length;i++){
        const l = log[i];
        const logTime = l.fromInning*2 + (l.fromHalf==="top"?0:1);
        const abTime  = ab.inning*2 + (ab.half==="top"?0:1);
        if(logTime < abTime) {
          activePIdx = l.pitcherIdx;
        } else if(logTime === abTime) {
          // 同イニング・ハーフ内はアウトカウントで判定
          if((l.outsAtStart||0) <= (ab.outsAtAb||0)) activePIdx = l.pitcherIdx;
        }
      }

      const ps = stats[activePIdx];
      if(!ps) return;
      const code = ab.entry.code;
      if(HIT_CODES.has(code)) ps.autoH++;
      if(code==="BB") ps.autoBb++;
      if(code==="K"||code==="KL"||code==="KW") ps.autoK++;
      
      ps.autoEr += ab.entry.runs||0;
    });

    
    
    allAtBats.forEach(ab=>{
      let activePIdx = log[0].pitcherIdx;
      for(let i=0;i<log.length;i++){
        const l = log[i];
        const logTime = l.fromInning*2+(l.fromHalf==="top"?0:1);
        const abTime  = ab.inning*2+(ab.half==="top"?0:1);
        if(logTime < abTime) {
          activePIdx = l.pitcherIdx;
        } else if(logTime === abTime) {
          if((l.outsAtStart||0) <= (ab.outsAtAb||0)) activePIdx = l.pitcherIdx;
        }
      }
      const ps = stats[activePIdx];
      if(!ps) return;
      const code = ab.entry.code;
      if(OUT_CODES.has(code)) ps._outsGot += 1;
      if(code==="DP") ps._outsGot += 1; 
    });

    stats.forEach(ps=>{
      ps.autoIp = Math.floor(ps._outsGot/3)*10 + (ps._outsGot%3); 
    });

    result[defTeam] = stats;
  });
  return result;
};

const newGame = (innings=7) => ({
  id:Date.now(),
  date:new Date().toISOString().split("T")[0],
  innings: innings,
  venue:"", awayTeam:"ビジターチーム", homeTeam:"ホームチーム",
  awayScore:emptyScore(innings), homeScore:emptyScore(innings),
  awayLineup:makeLineup(), homeLineup:makeLineup(),
  awayPitchers:makePitchers(), homePitchers:makePitchers(),
  defenseLog:[], 
  outs:0, bases:[null,null,null], inning:1, half:"top", log:[], runs:[], 
  finished:false, endReason:"", endInning:null, endNote:"",
  awayBatterIdx:0, homeBatterIdx:0, 
  awayPitcherIdx:0, homePitcherIdx:0, 
  
  awayPitcherLog:[], homePitcherLog:[],
});

// Firebase helpers
let fbDB = null;
const genGameId = () => Math.random().toString(36).slice(2,8).toUpperCase();
const fbInit = () => {
  if (fbDB) return true;
  try {
    const cfg = (typeof window!=="undefined") && window.__FB_CONFIG__;
    if (!cfg) { console.warn("[FB] No config"); return false; }
    const fb = (typeof window!=="undefined") && window.firebase;
    if (!fb) { console.warn("[FB] No SDK"); return false; }
    if (typeof fb.database !== "function") { console.warn("[FB] No database module"); return false; }
    if (!fb.apps || !fb.apps.length) fb.initializeApp(cfg);
    fbDB = fb.database();
    console.log("[FB] initialized OK");
    return true;
  } catch(e) { console.error("[FB] init error:", e); return false; }
};
const fbPush = (id, data) => {
  if (!fbDB || !id) return;
  try {
    var payload = Object.assign({}, data, {_ts: Date.now()});
    fbDB.ref("games/"+id).set(payload);
    console.log("[FB] pushed to games/"+id, new Date().toLocaleTimeString());
  } catch(e) { console.error("[FB] push error:", e); }
};
const fbSubscribe = (id, cb) => {
  if (!fbDB || !id) return ()=>{};
  const ref = fbDB.ref("games/"+id);
  ref.on("value", s => { if(s&&s.exists()) cb(s.val()); });
  return () => ref.off("value");
};

// チーム共有用Firebase関数
const fbSaveTeam = (team) => {
  if (!fbInit()) return;
  try {
    fbDB.ref("shared_teams/"+team.id).set({...team, _ts: Date.now()});
    console.log("[FB] team saved:", team.id);
  } catch(e) { console.error("[FB] team save error:", e); }
};

// チームに試合データを丸ごと保存（閲覧時に集計）
const fbSaveTeamGame = (teamId, game) => {
  if(!fbInit()||!teamId||!game) return;
  try {
    const sumScore = (sc) => Object.values(sc||{}).reduce((s,v)=>s+(parseInt(v)||0),0);
    // lineup丸ごと + 投手成績を保存（閲覧時に毎回集計する）
    const payload = {
      id: game.id,
      date: game.date||"",
      innings: game.innings||9,
      awayTeam: game.awayTeam,
      homeTeam: game.homeTeam,
      awayScoreTotal: sumScore(game.awayScore),
      homeScoreTotal: sumScore(game.homeScore),
      awayScore: game.awayScore||{},
      homeScore: game.homeScore||{},
      awayLineup: game.awayLineup||[],
      homeLineup: game.homeLineup||[],
      awayPitchers: game.awayPitchers||[],
      homePitchers: game.homePitchers||[],
      pitcherResults: game.pitcherResults||{},
      endReason: game.endReason||"",
      savedAt: Date.now(),
    };
    fbDB.ref("shared_teams/"+teamId+"/games/"+game.id).set(payload);
    console.log("[FB] team game saved:", game.id);
  } catch(e){ console.error("[FB] team game save error:", e); }
};

const fbDeleteTeam = (id) => {
  if (!fbInit()) return;
  try {
    fbDB.ref("shared_teams/"+id).remove();
    console.log("[FB] team deleted:", id);
  } catch(e) { console.error("[FB] team delete error:", e); }
};
const fbWatchTeams = (cb) => {
  if (!fbInit()) return null; // nullを返してuseEffect側でリトライ
  const ref = fbDB.ref("shared_teams");
  ref.on("value", s => {
    const val = s ? s.val() : null;
    const teams = val ? Object.values(val).filter(t=>t&&t.id).sort((a,b)=>(a._ts||0)-(b._ts||0)) : [];
    cb(teams);
  });
  return () => ref.off("value");
};
const fbUnsub = (id) => { if(fbDB&&id) try{fbDB.ref("games/"+id).off("value");}catch(e){} };

// ===== 大会管理 Firebase =====
const fbTournamentSave = (t) => {
  if(!fbDB||!t||!t.code) return;
  try { fbDB.ref("tournaments/"+t.code).set({...t, _ts:Date.now()}); } catch(e){}
};
const fbTournamentGet = (code, cb) => {
  if(!fbDB||!code) { cb(null); return ()=>{}; }
  const ref = fbDB.ref("tournaments/"+code.toUpperCase());
  ref.once("value", s => cb(s?s.val():null));
  return ()=>{};
};
const fbTournamentListen = (code, cb) => {
  if(!fbDB||!code) return ()=>{};
  const ref = fbDB.ref("tournaments/"+code.toUpperCase());
  ref.on("value", s => cb(s?s.val():null));
  return () => ref.off("value");
};
const fbTournamentAddGame = (code, game) => {
  if(!fbDB||!code||!game) return;
  try { fbDB.ref("tournaments/"+code.toUpperCase()+"/games/"+game.id).set({
    id:game.id, date:game.date||"", innings:game.innings||9,
    awayTeam:game.awayTeam, homeTeam:game.homeTeam,
    awayScore:Object.values(game.awayScore||{}).reduce((s,v)=>s+(parseInt(v)||0),0),
    homeScore:Object.values(game.homeScore||{}).reduce((s,v)=>s+(parseInt(v)||0),0),
    finished:!!game.finished, _ts:Date.now(),
  }); } catch(e){}
};

const SKEY = "bb_v7";
const lsLoad = () => { 
  try {
    const raw = localStorage.getItem(SKEY);
    if (!raw) return {};
    if (raw.length > 500000) { localStorage.removeItem(SKEY); return {}; } // 500KB超はクリア
    return JSON.parse(raw) || {};
  } catch(e2) { return {}; }
};
const lsSave = (d) => { 
  try {
    const s = JSON.stringify(d);
    if (s.length > 500000) return; // 500KB超は保存しない
    localStorage.setItem(SKEY, s);
  } catch(e3) {}
};
function App() {
  const [storage, setStorage] = useState(()=>{
    const s=lsLoad();
    if(!s.currentGame) s.currentGame=newGame();
    if(!s.history)     s.history=[];
    if(!s.undoStack)   s.undoStack=[];
    if(!s.teams)       s.teams=[];   
    return s;
  });
  const [tab,   setTab]   = useState("score");
  const [syncMode,   setSyncMode]   = useState("off");
  const [syncGameId, setSyncGameId] = useState("");
  const [viewerCode, setViewerCode] = useState("");
  const [viewerGame, setViewerGame] = useState(null);
  const [viewerTeamId, setViewerTeamId] = useState("");
  const [viewerTeamData, setViewerTeamData] = useState(null);
  const [viewerAdminInput, setViewerAdminInput] = useState("");
  const [isTeamAdmin, setIsTeamAdmin] = useState(false);
  const [teamSyncStatus, setTeamSyncStatus] = useState("idle"); // idle/syncing/ok/error
  const isViewer = syncMode==="viewer";
  const isHost   = syncMode==="host";
  const [modal, setModal] = useState(null);
  const [newInnings, setNewInnings] = useState(7);
  const [tournament, setTournament] = useState(null); // 現在参加中の大会データ
  const [tournamentCode, setTournamentCode] = useState(""); // 入力中のコード
  const [tournamentMsg, setTournamentMsg] = useState("");
  const [tournamentTab, setTournamentTab] = useState("top"); // top/teams/games/ranking
  const [selDir, setSelDir] = useState(null);
  const [toast,  setToast]  = useState("");

  const game      = storage.currentGame;
  const history   = storage.history||[];
  const undoStack = storage.undoStack||[];
  const teams     = storage.teams||[];

  useEffect(()=>lsSave(storage),[storage]);

  useEffect(()=>{
    if(isHost && syncGameId) {
      if(!fbInit()){ showToast("Firebase未設定"); return; }
      fbPush(syncGameId, storage.currentGame);
      console.log("[HOST] push triggered, syncGameId="+syncGameId);
    }
  },[storage, isHost, syncGameId]);

  // viewer subscribeはstartViewing内で直接実行するためここでは不要
  useEffect(()=>{
    if(!isViewer || !syncGameId) return;
  },[isViewer, syncGameId]);

  const showToast = (msg)=>{setToast(msg);setTimeout(()=>setToast(""),2600);};

  const startHosting = ()=>{
    if(!fbInit()){showToast("Firebase未設定");return;}
    const id=genGameId();
    setSyncGameId(id); setSyncMode("host");
    fbPush(id, storage.currentGame);
    showToast("配信開始！コード: "+id);
  };
  const stopHosting = ()=>{ setSyncMode("off"); setSyncGameId(""); showToast("配信終了"); };
  const startViewing = (id)=>{
    try {
      var uid = (id||'').trim().toUpperCase();
      if(uid.length!==6){ showToast("6桁のコードを入力してください"); return; }
      var cfg = window.__FB_CONFIG__;
      if(!cfg){ showToast("Firebase設定なし"); return; }
      var fb = window.firebase;
      if(!fb){ showToast("Firebase SDKなし"); return; }
      if(!fb.apps || !fb.apps.length) fb.initializeApp(cfg);
      if(!fbDB) fbDB = fb.database();
      setSyncGameId(uid);
      setSyncMode("viewer");
      showToast("観戦開始: "+uid);
      // ポーリングで3秒ごとに取得
      if(window.__viewerTimer) clearInterval(window.__viewerTimer);
      window.__viewerTimer = setInterval(function(){
        fbDB.ref("games/"+uid).once("value").then(function(snap){
          try {
            if(!snap||!snap.exists()) return;
            var d = snap.val();
            if(!d || typeof d !== 'object') return;
            delete d._ts;
            setViewerGame(d);
          } catch(e2){}
        }).catch(function(){});
      }, 1000);
    } catch(e){ showToast("エラー: "+e.message); }
  };
  // Firebaseチーム共有の監視（マウント時に開始・SDK読み込み待ちリトライ）
  useEffect(() => {
    setTeamSyncStatus("syncing");
    let unsub = null;
    let retryCount = 0;
    const maxRetry = 10;

    const tryStart = () => {
      unsub = fbWatchTeams((fbTeams) => {
        setStorage(s => ({...s, teams: fbTeams}));
        setTeamSyncStatus("ok");
      });
      if (unsub === null) {
        // Firebase SDKがまだ準備できていない→リトライ
        retryCount++;
        if (retryCount < maxRetry) {
          setTimeout(tryStart, 800);
        } else {
          setTeamSyncStatus("error");
        }
      }
    };
    tryStart();
    return () => { if (unsub) unsub(); };
  }, []);

  const startViewingTeam = (tid)=>{
    const id = (tid||"").trim();
    if(!id){ showToast("チームIDを入力してください"); return; }
    if(!fbInit()){ showToast("Firebase未接続"); return; }
    fbDB.ref("shared_teams/"+id).once("value").then(snap=>{
      if(!snap||!snap.exists()){ showToast("チームが見つかりません"); return; }
      setViewerTeamData(snap.val());
      // リアルタイム更新
      fbDB.ref("shared_teams/"+id).on("value", s=>{ if(s&&s.val()) setViewerTeamData(s.val()); });
    });
  };

  const stopViewing = ()=>{
    if(syncGameId && fbDB) {
      try { fbDB.ref("games/"+syncGameId).off("value"); } catch(e){}
    }
    if(window.__viewerTimer){clearInterval(window.__viewerTimer);window.__viewerTimer=null;} setSyncMode("off"); setSyncGameId(""); showToast("観戦終了");
  };

  
  const mutGame = useCallback((fn)=>{
    setStorage(s=>{
      
      const snap = JSON.parse(JSON.stringify(s.currentGame));
      const newGame = fn(s.currentGame);
      const newUndoStack = [snap, ...(s.undoStack||[])];
      return {...s, currentGame:newGame, undoStack:newUndoStack};
    });
  },[]);

  
  const undoPlay = useCallback(()=>{
    setStorage(s=>{
      const stack = s.undoStack||[];
      if(stack.length===0){
        setToast("これ以上戻せません"); setTimeout(()=>setToast(""),2600);
        return s;
      }
      const [last, ...rest] = stack;
      setToast("↩ 1つ前に戻しました"); setTimeout(()=>setToast(""),2600);
      return {...s, currentGame:last, undoStack:rest};
    });
  },[]);

  const gameInnings = Array.from({length: game.innings||9}, (_,i)=>i+1);
  const awayTotal = calcTotal(game.awayScore);
  const homeTotal = calcTotal(game.homeScore);

  // エラー数・ヒット数をlineupから直接集計（_subOuts含む）
  const sumLineupE = (lu) => lu.reduce((s,p) => {
    let e = p.e||0;
    (p._subOuts||[]).forEach(so => { e += so.e||0; });
    if(p._subOut && !p._subOuts) e += p._subOut.e||0;
    return s+e;
  }, 0);
  const sumLineupH = (lu) => lu.reduce((s,p) => {
    const countH = (ab) => Object.values(ab||{}).flat().filter(en=>{const c=(en&&en.code)||en;return c==='H1'||c==='H2'||c==='H3'||c==='HR';}).length;
    let h = countH(p.atBats);
    (p._subOuts||[]).forEach(so => { h += countH(so.atBats); });
    if(p._subOut && !p._subOuts) h += countH(p._subOut.atBats);
    return s+h;
  }, 0);
  const awayErrsTotal = sumLineupE(game.awayLineup||[]);
  const homeErrsTotal = sumLineupE(game.homeLineup||[]);
  const awayHitsTotal = sumLineupH(game.awayLineup||[]);
  const homeHitsTotal = sumLineupH(game.homeLineup||[]);

  const RBI_CODES = new Set(["H1","H2","H3","HR","BB","HBP","SAC","SF"]);
  const commitAtBat = useCallback((team, pidx, inning, code, dir, scoredNames, newBases, newOuts, errorPos)=>{
    const runs = (scoredNames||[]).length;
    const batterName = (() => { try { return _optionalChain([game, 'access', _4 => _4[team+"Lineup"], 'access', _5 => _5[pidx], 'optionalAccess', _6 => _6.name])||""; } catch(e){return "";} })();
    const batterScored = (scoredNames||[]).includes(batterName);
    const entry = {code, ...(dir?{dir}:{}), runs, ...(batterScored?{scored:true}:{}), ...(errorPos?{errorPos}:{})};
    let nextPidx = -1;
    mutGame(g=>{
      const lk=team+"Lineup";
      const rbiAdd = (RBI_CODES.has(code) && (runs||0)>0) ? (runs||0) : 0;
      const lineup=g[lk].map((p,i)=>{
        if(i===pidx) {
          const prev=toList(p.atBats,inning);
          return {...p,
            atBats:{...p.atBats,[inning]:[...prev,entry]},
            rbi:(p.rbi||0)+rbiAdd,
            // HR等で打者自身が得点した場合はrunも+1
            run: batterScored ? (p.run||0)+1 : (p.run||0),
          };
        }
        // ランナーとして得点した選手にscored記録を追加
        if((scoredNames||[]).includes(p.name) && p.name !== batterName) {
          return {...p, run:(p.run||0)+1};
        }
        return p;
      });
      
      let defLineupUpdate = {};
      if(errorPos){
        const defTeam = team==="away"?"home":"away";
        const defLk = defTeam+"Lineup";
        const defLineup = g[defLk].map(p => {
          // 現在その守備位置にいる選手（交代後も含む）
          if(p.pos===errorPos) return {...p, e:(p.e||0)+1};
          return p;
        });
        defLineupUpdate = {[defLk]:defLineup};
      }
      const changeOccurs = newOuts>=3;
      const tmp={...g, [lk]:lineup, ...defLineupUpdate,
        bases: newBases!==undefined ? newBases : g.bases,
        outs:  newOuts!==undefined  ? (changeOccurs?0:newOuts) : g.outs,
        inning: changeOccurs ? (g.half==="top"?g.inning:Math.min(g.inning+1,15)) : g.inning,
        half:   changeOccurs ? (g.half==="top"?"bottom":"top") : g.half,
      };
      const batterKey = team+"BatterIdx";
      const lineupLen = lineup.length;
      nextPidx = (pidx+1) % lineupLen;
      const scores=recomputeScores(tmp);
      const zl=ZONES.find(z=>z.id===dir);
      const baseLabel = b => b===0?'一塁':b===1?'二塁':b===2?'三塁':b==='scored'?'得点':b==='out'?'アウト':'?';
      // ランナー移動サマリー（手動調整分）
      const preBasesSnap = g.bases || [null,null,null];
      let runnerNote = '';
      if(newBases !== undefined) {
        const moved = [];
        // 得点したランナー
        (scoredNames||[]).forEach(n => { if(n !== batterName) moved.push(n+'→得点'); });
        // 塁上に残ったランナーの移動
        [0,1,2].forEach(j => {
          const nb = newBases[j];
          if(nb && nb !== batterName) {
            // 元の塁を探す
            const from = preBasesSnap.indexOf(nb);
            if(from !== -1 && from !== j) moved.push(nb+'→'+(j===0?'一':j===1?'二':'三')+'塁');
          }
        });
        if(moved.length) runnerNote = ' (' + moved.join(', ') + ')';
      }
      const log=[{
        ts:new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit"}),
        msg:`【${g[team+"Team"]}】${lineup[pidx].name} → ${_optionalChain([rOf, 'call', _7 => _7(code), 'optionalAccess', _8 => _8.label])||code}${zl?`(${zl.label})`:""}${(runs||0)>0?` [${runs}点]`:""}${runnerNote}（${inning}回）`
      },...g.log.slice(0,99)];
      return {...tmp,...scores,log,[batterKey]:nextPidx};
    });
    setSelDir(null);
    
    const wasChange = newOuts>=3;
    if(wasChange){
      setModal(null);
      showToast(`チェンジ！ ${_optionalChain([rOf, 'call', _9 => _9(code), 'optionalAccess', _10 => _10.label])||code} 記録`);
    } else {
      showToast(`${_optionalChain([rOf, 'call', _11 => _11(code), 'optionalAccess', _12 => _12.label])||code}${(runs||0)>0?` +${runs}点`:""} ✅`);
      
      setTimeout(()=>{
        setModal({team, pidx:nextPidx, inning, step:"result"});
      }, 350);
    }
  },[mutGame]);

  
  const overwriteEntry = useCallback((team,pidx,inning,eidx,code,dir,runs)=>{
    const entry={code,...(dir?{dir}:{}),runs:runs||0};
    mutGame(g=>{
      const lk=team+"Lineup";
      const lineup=g[lk].map((p,i)=>{
        if(i!==pidx) return p;
        const list=[...toList(p.atBats,inning)]; list[eidx]=entry;
        return {...p,atBats:{...p.atBats,[inning]:list}};
      });
      const tmp={...g,[lk]:lineup};
      const scores=recomputeScores(tmp);
      const zl=ZONES.find(z=>z.id===dir);
      const log=[{
        ts:new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit"}),
        msg:`【修正】${lineup[pidx].name} ${inning}回 → ${_optionalChain([rOf, 'call', _13 => _13(code), 'optionalAccess', _14 => _14.label])||code}${zl?`(${zl.label})`:""}${(runs||0)>0?` [${runs}点]`:""}`
      },...g.log.slice(0,99)];
      return {...tmp,...scores,log};
    });
    setModal(null); setSelDir(null);
    showToast("修正しました");
  },[mutGame]);

  
  const deleteEntry = useCallback((team,pidx,inning,eidx)=>{
    mutGame(g=>{
      const lk=team+"Lineup";
      const lineup=g[lk].map((p,i)=>{
        if(i!==pidx) return p;
        const list=[...toList(p.atBats,inning)]; list.splice(eidx,1);
        return {...p,atBats:{...p.atBats,[inning]:list}};
      });
      return {...g,[lk]:lineup,...recomputeScores({...g,[lk]:lineup})};
    });
    setModal(null); showToast("削除しました");
  },[mutGame]);

  
  const recordSB = useCallback((team,pidx,type,runner,destBi)=>{
    // destBi: 進塁先の塁インデックス (0=1塁,1=2塁,2=3塁,3=ホーム)
    mutGame(g=>{
      const lk=team+"Lineup";
      const lineup=g[lk].map((p,i)=>{
        if(i!==pidx) return p;
        if(type==="SB") return {...p, sb:(p.sb||0)+1};
        return {...p, cs:(p.cs||0)+1};
      });

      let newBases = [...g.bases];
      let scoreAdd = 0;
      let scoredRunner = null;

      if(runner){
        if(type==="SB"){
          newBases[runner.bi] = null;
          if(destBi >= 3){
            // ホームイン
            scoreAdd = 1;
            scoredRunner = runner.name;
          } else {
            newBases[destBi] = runner.name;
          }
        } else {
          // CS / PO: アウトになったランナーを除去
          newBases[runner.bi] = null;
        }
      }

      // チームスコアに直接加算（recomputeScoresは使わない）
      const inning = g.inning;
      const scoreKey = team+"Score";
      const newScore = scoreAdd>0
        ? {...g[scoreKey], [inning]: (parseInt(g[scoreKey][inning])||0) + scoreAdd}
        : g[scoreKey];

      // ホームインした選手の個人得点加算
      let updatedLineup = lineup;
      if(scoredRunner){
        updatedLineup = lineup.map(p=>
          p.name===scoredRunner ? {...p, run:(p.run||0)+1} : p
        );
      }

      const destLabel = destBi>=3 ? "ホーム" : ["1塁","2塁","3塁"][destBi??0];
      const fromLabel = ["1塁","2塁","3塁"][runner?.bi??0];
      const baseLabel = runner ? `${fromLabel}→${destLabel}` : "";
      const log=[{
        ts:new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit"}),
        msg:`【${g[team+"Team"]}】${_optionalChain([runner, 'optionalAccess', _15 => _15.name])||lineup[pidx].name} → ${type==="SB"?`盗塁成功(${baseLabel})`:type==="PO"?"牽制アウト":"盗塁刺"}${scoreAdd>0?" [1点]":""}`
      },...g.log.slice(0,99)];

      const outs = (type==="CS"||type==="PO") ? Math.min(g.outs+1,3) : g.outs;
      const changeOccurs = outs>=3;
      // 3アウトでイニングチェンジ → ランナーをリセット
      const finalBases = changeOccurs ? [null,null,null] : newBases;
      return {...g,
        [lk]:updatedLineup,
        [scoreKey]:newScore,
        bases:finalBases,
        outs:changeOccurs?0:outs,
        inning:changeOccurs?(g.half==="top"?g.inning:Math.min(g.inning+1,15)):g.inning,
        half:changeOccurs?(g.half==="top"?"bottom":"top"):g.half,
        log};
    });
    setModal(null);
    showToast(type==="SB"?"盗塁✅":type==="PO"?"牽制アウト❌":"盗塁刺❌");
  },[mutGame]);

  
  const recordSpecialPlay = useCallback((team, code, advanceBases, runs)=>{
    const sp = SPECIAL_PLAYS.find(p=>p.code===code);
    mutGame(g=>{
      const newBases = advanceBases !== undefined ? advanceBases : g.bases;
      // 得点したランナー名を特定（元の塁から消えて新basesにもいない選手）
      const oldBases = g.bases || [null,null,null];
      const scoredRunners = (oldBases).filter(n => n && !(newBases||[]).includes(n));
      const updatedLineup = g[team+"Lineup"].map(p => {
        if(scoredRunners.includes(p.name)) return {...p, run:(p.run||0)+1};
        return p;
      });
      
      const scoreKey = team+"Score";
      const inn = g.inning;
      const prevRuns = parseInt(g[scoreKey][inn])||0;
      const scores = runs>0 ? {...g[scoreKey],[inn]:prevRuns+runs} : g[scoreKey];
      const log=[{
        ts:new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit"}),
        msg:`【${g[team+"Team"]}】${_optionalChain([sp, 'optionalAccess', _16 => _16.label])||code}${runs>0?` [${runs}点]`:""}`
      },...g.log.slice(0,99)];
      return {...g,
        [team+"Lineup"]: updatedLineup,
        [scoreKey]:scores,
        bases:newBases,
        log,
      };
    });
    setModal(null);
    showToast(`${_optionalChain([sp, 'optionalAccess', _17 => _17.label])||code}記録`);
  },[mutGame]);

  
  const openNew     = (team,pidx,inning) => { setSelDir(null); setTab("score"); setModal({team,pidx,inning,step:"result"}); };
  const openSB      = (team,pidx)        => setModal({team,pidx,step:"sb"});
  const openEdit    = (team,pidx,inning) => { setSelDir(null); setTab("score"); setModal({team,pidx,inning,step:"edit_list"}); };
  const openSpecial = (team)             => setModal({team,step:"special"});
  
  const openCurrentBatter = (team,inning) => {
    const batterKey = team+"BatterIdx";
    const idx = game[batterKey]||0;
    setSelDir(null);
    setModal({team, pidx:idx, inning, step:"result"});
  };

  
  const onPickResult = (code) => {
    const { newBases, runs, newOuts, batterScored, scoredNames } = applyResult(code, game.bases, game.outs, _optionalChain([mPlayer, 'optionalAccess', _18 => _18.name]));
    const base = {autoNewBases:newBases, autoRuns:runs, autoNewOuts:newOuts, batterScored, autoScoredNames:scoredNames};
    if (code === "E") {
      
      setSelDir(null);
      setModal(m=>({...m, step:"direction", pendingCode:code, ...base, afterDir:"error_pos"}));
    } else if (DIR_CODES.has(code)) {
      setSelDir(null);
      setModal(m=>({...m, step:"direction", pendingCode:code, ...base}));
    } else {
      setModal(m=>({...m, step:"adjust", pendingCode:code, pendingDir:null, ...base}));
    }
  };

  const onPickResultForEdit = (code) => {
    if(DIR_CODES.has(code)){ setSelDir(null); setModal(m=>({...m,step:"direction_edit",pendingCode:code})); }
    else setModal(m=>({...m,step:"adjust_edit",pendingCode:code,pendingDir:null,autoRuns:0,autoNewBases:game.bases,autoNewOuts:game.outs}));
  };

  const onConfirmDir = () => {
    const code = modal.pendingCode;
    const { newBases, runs, newOuts, batterScored, scoredNames } = applyResult(code, game.bases, game.outs, _optionalChain([mPlayer, 'optionalAccess', _19 => _19.name]));
    const nextStep = modal.afterDir || "adjust";
    setModal(m=>({...m, step:nextStep, pendingDir:selDir||null,
      autoNewBases:newBases, autoRuns:runs, autoNewOuts:newOuts, batterScored, autoScoredNames:scoredNames,
      afterDir:undefined}));
    setSelDir(null);
  };
  const onConfirmDirEdit = () => {
    setModal(m=>({...m,step:"adjust_edit",pendingDir:selDir||null,autoRuns:0,autoNewBases:game.bases,autoNewOuts:game.outs}));
    setSelDir(null);
  };

  
  const changeInning=()=>{
    mutGame(g=>{
      
      if(g.half==="top") return{...g,half:"bottom",outs:0,bases:[null,null,null]};
      return{...g,inning:Math.min(g.inning+1,15),half:"top",outs:0,bases:[null,null,null]};
    });
    showToast("チェンジ！");
  };
  const addOut=()=>mutGame(g=>{
    const outs=(g.outs+1)%4;
    return{...g,outs,bases:outs===0?[null,null,null]:g.bases};
  });
  const toggleBase=(i)=>mutGame(g=>{
    const b=[...g.bases];
    b[i]=b[i]?null:"ランナー"; 
    return{...g,bases:b};
  });

  
  const makeTeamId = () => Date.now().toString(36);
  const saveTeam = (team) => {
    const teamWithId = team.id ? team : {...team, id:makeTeamId()};
    // Firebaseに保存（全員に共有）
    fbSaveTeam(teamWithId);
    // ローカルにも即時反映
    setStorage(s => {
      const existing = (s.teams||[]).findIndex(t=>t.id===teamWithId.id);
      const teams = existing>=0
        ? s.teams.map(t=>t.id===teamWithId.id?teamWithId:t)
        : [...(s.teams||[]), teamWithId];
      return {...s, teams};
    });
    showToast(`「${team.name}」を保存しました`);
  };
  const deleteTeam = (id) => {
    setModal({step:"confirm_delete_team", targetTeamId:id});
  };
  
  const applyTeamToLineup = (side, team) => {
    mutGame(g=>{
      const lk = side+"Lineup";
      const members = team.members||[];
      const newLineup = members.map((m,i)=>({
        ...makePlayer(i+1),
        name: typeof m==="string" ? m : (m.name||`選手${i+1}`),
        pos: typeof m==="object" && m.pos ? m.pos : String(i+1),
      }));
      while(newLineup.length < DEFAULT_PLAYERS){
        newLineup.push(makePlayer(newLineup.length+1));
      }
      const updated = {...g, [lk]:newLineup, [side+"Team"]:team.name};
      return syncPitcherFromLineup(updated, side);
    });
    showToast(`${team.name} のスタメンをセットしました`);
  };

  
  const syncPitcherFromLineup = (g, side) => {
    const pitcher = g[side+"Lineup"].find(p=>p.pos==="投");
    if(!pitcher) return g;
    const pitchers = [...g[side+"Pitchers"]];
    const currentPIdx = g[side+"PitcherIdx"]||0;
    const currentPitcher = pitchers[currentPIdx];
    
    if(_optionalChain([currentPitcher, 'optionalAccess', _20 => _20.name]) === pitcher.name) return g;
    
    const existIdx = pitchers.findIndex(p=>p.name===pitcher.name);
    if(existIdx >= 0){
      
      return {...g, [side+"PitcherIdx"]: existIdx};
    }
    
    const newPitcher = {...makePitcher(pitchers.length+1), name: pitcher.name};
    const newPitchers = [...pitchers, newPitcher];
    const newPIdx = newPitchers.length-1;
    const logKey = side+"PitcherLog";
    const newPitcherLog = [...(g[logKey]||[]), {
      pitcherIdx: newPIdx,
      fromInning: g.inning,
      fromHalf: g.half,
      outsAtStart: g.outs,
    }];
    return {...g,
      [side+"Pitchers"]: newPitchers,
      [side+"PitcherIdx"]: newPIdx,
      [logKey]: newPitcherLog,
    };
  };

  
  const substitutePlayer = useCallback((team, outIdx, newName, newPos, reason)=>{
    mutGame(g=>{
      const lk = team+"Lineup";
      const outPlayer = g[lk][outIdx];
      const isPosChange = newName === outPlayer.name; // 同名＝ポジション変更のみ

      const lineup = g[lk].map((p,i)=>{
        if(i!==outIdx) return p;

        if(isPosChange) {
          // ポジション変更のみ → _subOut不要、posだけ更新
          return {...p, pos: newPos};
        }

        // 選手交代 → 元選手を_subOuts配列に追記（チェーン対応）
        const prevSubOuts = p._subOuts || [];
        // 既に_subOutが1件ある古い形式も吸収
        const legacySubOut = p._subOut && !p._subOuts ? [p._subOut] : [];
        const allPrevious = [...legacySubOut, ...prevSubOuts, {
          name: outPlayer.name,
          pos: outPlayer.pos || "",
          atBats: p.atBats || {},
          sb: p.sb || 0,
          cs: p.cs || 0,
          run: p.run || 0,
          e: p.e || 0,
        }];

        return {
          ...p,
          _subOuts: allPrevious,
          _subOut: null, // 古い形式はクリア
          name: newName,
          pos: newPos,
          subbed: true,
          subNote: reason || "",
          prevName: outPlayer.name,
          atBats: {}, sb: 0, cs: 0, run: 0, e: 0,
        };
      });

      const ts = new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit"});
      const log=[{
        ts,
        msg: isPosChange
          ? `【${g[team+"Team"]}】ポジション変更: ${outPlayer.name} ${outPlayer.pos||"-"}→${newPos} (${g.inning}回${g.half==="top"?"表":"裏"})`
          : `【${g[team+"Team"]}】交代: ${outPlayer.name}(${outPlayer.pos||"-"}) → ${newName}(${newPos||"-"})${reason?` [${reason}]`:""} (${g.inning}回${g.half==="top"?"表":"裏"})`
      },...g.log.slice(0,99)];

      const defEntry = {
        inning:g.inning, half:g.half, team,
        outName:outPlayer.name, outPos:outPlayer.pos||"",
        inName:newName, inPos:newPos||"",
        reason:reason||"", ts,
      };
      const defenseLog = [...(g.defenseLog||[]), defEntry];
      const updated = {...g,[lk]:lineup,log,defenseLog};
      return syncPitcherFromLineup(updated, team);
    });
  },[mutGame]);

  const changePitcher = useCallback((defTeam, newPitcherIdx)=>{
    mutGame(g=>{
      const logKey = defTeam+"PitcherLog";
      // 新投手が実際に投げるハーフ
      // away投手 → 表(top)、home投手 → 裏(bottom)
      const pitchHalf = defTeam==="away" ? "top" : "bottom";
      const sameHalf = g.half === pitchHalf;
      // 同ハーフ中に交代 → 今のイニング・今のアウトから
      // 違うハーフ（例:4回裏にaway投手交代）→ 次のイニングの同ハーフ頭から
      // ただし「違うハーフ」とは今が裏でaway交代 or 今が表でhome交代の場合
      // その場合は次のイニング（4回裏→5回表、4回表→4回裏…はhome）
      // away: 今が裏(bottom)なら次は(inning+1)の表、今が表なら今のイニングの表
      // home: 今が表(top)なら今のイニングの裏、今が裏なら今のイニングの裏
      const fromInning = sameHalf ? g.inning
        : (defTeam==="away" ? g.inning + 1 : g.inning);
      const fromHalf = pitchHalf;
      const entry = {
        pitcherIdx: newPitcherIdx,
        fromInning,
        fromHalf,
        outsAtStart: sameHalf ? g.outs : 0,
      };
      const newLog = [...(g[logKey]||[]), entry];
      const log=[{
        ts:new Date().toLocaleTimeString("ja-JP",{hour:"2-digit",minute:"2-digit"}),
        msg:`【${g[defTeam+"Team"]}】投手交代: ${_optionalChain([g, 'access', _21 => _21[defTeam+"Pitchers"], 'access', _22 => _22[newPitcherIdx], 'optionalAccess', _23 => _23.name])||"新投手"} 登板（${g.inning}回${g.half==="top"?"表":"裏"}）`
      },...g.log.slice(0,99)];
      return {...g,[defTeam+"PitcherIdx"]:newPitcherIdx,[logKey]:newLog,log};
    });
  },[mutGame]);

  
  const exportExcel = useCallback((targetGame) => {
    const doExport = (XLSX) => {
    const g = targetGame || game;
    const aStats = computeStats(g.awayLineup);
    const hStats = computeStats(g.homeLineup);
    const pStats = computePitcherStats(g);
    const wb = XLSX.utils.book_new();
    const title = `${g.awayTeam} vs ${g.homeTeam} (${g.date})`;

    
    const batHeader = ["チーム","#","選手名","打席","打数","安打","二塁打","三塁打","本塁打","打点","四球","死球","三振","失策","盗塁","盗刺","得点","打率","長打率","出塁率","OPS"];
    const batRows = [batHeader];
    [[g.awayTeam, aStats],[g.homeTeam, hStats]].forEach(([teamName, stats])=>{
      let totals = {pa:0,ab:0,h:0,h2:0,h3:0,hr:0,rbi:0,bb:0,hbp:0,k:0,e:0,sb:0,cs:0,r:0};
      stats.forEach((p,i)=>{
        
        let h2=0,h3=0;
        Object.values(p.atBats).flat().forEach(e=>{
          const code = (typeof e==="object"&&e!==null)?e.code:e;
          if(code==="H2") h2++;
          if(code==="H3") h3++;
        });
        batRows.push([teamName,i+1,p.name,p._pa||0,p._ab,p._h,h2,h3,p._hr,p.rbi||0,p._bb,p._hbp||0,p._k,p.e||0,p.sb||0,p.cs||0,p._r||0,p._avg,p._slg||".---",p._obp||".---",p._ops||".---"]);
        totals.ab+=p._ab; totals.h+=p._h; totals.h2+=h2; totals.h3+=h3; totals.hr+=p._hr;
        totals.rbi+=p.rbi||0; totals.bb+=p._bb; totals.hbp+=(p._hbp||0); totals.k+=p._k; totals.e+=p.e||0;
        totals.sb+=p.sb||0; totals.cs+=p.cs||0; totals.r+=(p._r||0); totals.pa+=(p._pa||0);
      });
      const avg = totals.ab>0?(totals.h/totals.ab).toFixed(3).replace(/^0/,""):".---";
      batRows.push([teamName+"合計","","",totals.pa,totals.ab,totals.h,totals.h2,totals.h3,totals.hr,totals.rbi,totals.bb,totals.hbp,totals.k,totals.e,totals.sb,totals.cs,totals.r,avg]);
      batRows.push([]);
    });
    const wsBat = XLSX.utils.aoa_to_sheet(batRows);
    wsBat["!cols"] = [10,4,10,5,5,6,6,6,5,5,5,5,5,5,7].map(w=>({wch:w}));
    XLSX.utils.book_append_sheet(wb, wsBat, "打撃成績");

    
    const pitHeader = ["チーム","投手名","投球回","被安打","自責点","四球","三振","防御率"];
    const pitRows = [pitHeader];
    [[g.awayTeam,"away"],[g.homeTeam,"home"]].forEach(([teamName,side])=>{
      const pitchers = g[side+"Pitchers"];
      const autoStats = pStats[side]||[];
      pitchers.forEach((p,i)=>{
        const auto = autoStats[i]||{autoIp:0,autoH:0,autoEr:0,autoBb:0,autoK:0};
        const isOverride = p.manualOverride;
        const ip  = isOverride ? p.ip   : auto.autoIp;
        const h   = isOverride ? p.h    : auto.autoH;
        const er  = isOverride ? p.er   : auto.autoEr;
        const bb  = isOverride ? p.bb   : auto.autoBb;
        const k   = isOverride ? p.k    : auto.autoK;
        
        const ipNum = Math.floor(ip/10) + (ip%10)/3;
        const era = ipNum>0 ? (er*(g.innings||9)/ipNum).toFixed(2) : "---";
        const ipDisp = `${Math.floor(ip/10)}.${ip%10}`;
        pitRows.push([teamName,p.name,ipDisp,h,er,bb,k,era]);
      });
      pitRows.push([]);
    });
    const wsPit = XLSX.utils.aoa_to_sheet(pitRows);
    wsPit["!cols"] = [10,10,7,7,7,5,5,7].map(w=>({wch:w}));
    XLSX.utils.book_append_sheet(wb, wsPit, "投手成績");

    
    const scoreHeader = ["チーム","1","2","3","4","5","6","7","8","9","計"];
    const scoreRows = [scoreHeader];
    [["away",g.awayTeam],["home",g.homeTeam]].forEach(([side,name])=>{
      const row = [name];
      Array.from({length:g.innings||9},(_,i)=>i+1).forEach(i=>row.push(parseInt(g[side+"Score"][i])||0));
      row.push(calcTotal(g[side+"Score"]));
      scoreRows.push(row);
    });
    const wsScore = XLSX.utils.aoa_to_sheet(scoreRows);
    XLSX.utils.book_append_sheet(wb, wsScore, "スコアボード");

    const fname = `スコアブック_${g.awayTeam}_vs_${g.homeTeam}_${g.date}.xlsx`.replace(/[\/\:*?"<>|]/g,"_");
    
    if((g.defenseLog||[]).length>0){
      const defHeader = ["イニング","表裏","チーム","退く選手","守備位置","入る選手","守備位置","理由","時刻"];
      const defRows = [defHeader];
      (g.defenseLog||[]).forEach(d=>{
        defRows.push([
          d.inning,
          d.half==="top"?"表":"裏",
          d.team==="away"?g.awayTeam:g.homeTeam,
          d.outName, d.outPos,
          d.inName, d.inPos,
          d.reason||"", d.ts||""
        ]);
      });
      const wsDef = XLSX.utils.aoa_to_sheet(defRows);
      wsDef["!cols"] = [6,4,10,10,6,10,6,8,6].map(w=>({wch:w}));
      XLSX.utils.book_append_sheet(wb, wsDef, "守備交代");
    }
      XLSX.writeFile(wb, fname);
    };
    if(window.XLSX) {
      doExport(window.XLSX);
    } else {
      var s = document.createElement('script');
      s.src = 'https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js';
      s.onload = function(){ doExport(window.XLSX); };
      s.onerror = function(){ alert('Excel機能の読み込みに失敗しました。'); };
      document.head.appendChild(s);
    }
  }, [game]);

  
  const editPlayer  = (t,i,f,v)=>mutGame(g=>{
    const updated = {...g,[t+"Lineup"]:g[t+"Lineup"].map((p,j)=>j===i?{...p,[f]:v}:p)};
    
    if(f==="name"||f==="pos") return syncPitcherFromLineup(updated, t);
    return updated;
  });
  const editPitcher = (t,i,f,v)=>mutGame(g=>({...g,[t+"Pitchers"]:g[t+"Pitchers"].map((p,j)=>j===i?{...p,[f]:isNaN(v)?v:Number(v)}:p)}));
  const addPlayer   = (t)=>mutGame(g=>{const lk=t+"Lineup";const n=g[lk].length+1;return{...g,[lk]:[...g[lk],makePlayer(n)]};});

  
  const saveGame=()=>{
    setStorage(s=>({...s,history:[{...s.currentGame,savedAt:new Date().toLocaleString("ja-JP")},...s.history.slice(0,19)]}));
    showToast("保存しました");
  };

  const endGame = useCallback((reason, endInning, endNote, pitcherResults)=>{
    mutGame(g=>({...g, finished:true, endReason:reason, endInning, endNote:endNote||"", pitcherResults:pitcherResults||{}}));
    
    setStorage(s=>{
      const finished = {...s.currentGame, finished:true, endReason:reason, endInning, endNote:endNote||"",
        pitcherResults: pitcherResults||{},
        savedAt:new Date().toLocaleString("ja-JP")};

      // チームへの自動アップロード（lineup丸ごと保存）
      const g = finished;
      const matchedTeam = (s.teams||[]).find(t=>t.name===g.awayTeam||t.name===g.homeTeam);
      if(matchedTeam){
        fbSaveTeamGame(matchedTeam.id, g);
      }

      return {...s, history:[finished,...s.history.slice(0,19)]};
    });
    showToast(reason==="cold"?`コールドゲーム（${endInning}回）`:reason==="mercy"?"コールド成立":"⚾ 試合終了");
  },[mutGame]);

  const resumeGame = useCallback(()=>{
    mutGame(g=>({...g, finished:false, endReason:"", endInning:null, endNote:""}));
    showToast("試合を再開しました");
  },[mutGame]);
  const loadGame=(g)=>{
    setModal({step:"confirm_load", targetGame:g});
  };
  const delHistory=(id)=>{
    setModal({step:"confirm_delete", targetId:id});
  };
  const startNew=()=>{
    setModal({step:"confirm_new"});
  };

  const aStats=computeStats(game.awayLineup);
  const hStats=computeStats(game.homeLineup);
  const pitcherStats=computePitcherStats(game); 
  const curTeam   = game.half==="top"?"away":"home";
  const curLabel  = game.half==="top"?game.awayTeam:game.homeTeam;
  const curLineup = game.half==="top"?game.awayLineup:game.homeLineup;

  const mLineup    = modal ? (modal.team==="home"?game.homeLineup:game.awayLineup) : [];
  const mPlayer    = modal ? mLineup[modal.pidx] : null;
  const mTeamLabel = modal ? (modal.team==="home"?game.homeTeam:game.awayTeam) : "";

  
  // 観戦モード: シンプルな表示のみ（重いUIを描画しない）
  if (isViewer) {
    var vg     = viewerGame || game;
    var inning = vg ? (vg.inning||1) : 1;
    var half   = vg ? (vg.half||'top') : 'top';
    var topBot = half==='top' ? '表' : '裏';
    var outs   = vg ? (vg.outs||0) : 0;
    var rawBases = vg ? (vg.bases||[null,null,null]) : [null,null,null];
    var bases  = Array.isArray(rawBases) ? rawBases : [rawBases[0]||null, rawBases[1]||null, rawBases[2]||null];
    var awayScore = 0; var homeScore = 0;
    var asc = (vg && vg.awayScore)||{}; var hsc = (vg && vg.homeScore)||{};
    for(var k in asc) awayScore += parseInt(asc[k])||0;
    for(var k in hsc) homeScore += parseInt(hsc[k])||0;
    // ヒット数・エラー数集計
    var awayLu = (vg && vg.awayLineup)||[];
    var homeLu = (vg && vg.homeLineup)||[];
    var countHits = function(lu){ return lu.reduce(function(s,p){
      var ab = p.atBats||{}; var h=0;
      Object.values(ab).flat().forEach(function(e){ var c=(e&&e.code)||e; if(c==='H1'||c==='H2'||c==='H3'||c==='HR') h++; });
      return s+h;
    },0); };
    var countErrs = function(lu){ return lu.reduce(function(s,p){ return s+(p.e||0); },0); };
    var awayHits = countHits(awayLu); var homeHits = countHits(homeLu);
    var awayErrs = countErrs(awayLu); var homeErrs = countErrs(homeLu);
    var side  = half==='top' ? 'away' : 'home';
    var pside = half==='top' ? 'home' : 'away';
    var lu    = (vg && vg[side+'Lineup'])    || [];
    var ptrs  = (vg && vg[pside+'Pitchers']) || [];
    var bi    = (vg && vg[side+'BatterIdx'])    || 0;
    var pi2   = (vg && vg[pside+'pitcherIdx'])  || 0;
    var bat   = lu[bi]   || {};
    var pit   = ptrs[pi2]|| {};
    var batStr = (bat.num ? bat.num+'番 ' : '') + (bat.name || '－');
    var pitStr = pit.name || '－';
    var aName  = (vg && vg.awayTeam) || 'アウェイ';
    var hName  = (vg && vg.homeTeam) || 'ホーム';
    var INNS   = Array.from({length:(vg&&vg.innings)||9},(_,i)=>i+1);
    var vlog   = (vg && Array.isArray(vg.log)) ? vg.log : [];

    var b0 = bases[0] ? String(bases[0]) : null;
    var b1 = bases[1] ? String(bases[1]) : null;
    var b2 = bases[2] ? String(bases[2]) : null;

    // アウト丸
    var outDots = React.createElement('div', {style:{display:'flex',gap:7,alignItems:'center',justifyContent:'center',marginTop:6}},
      [0,1,2].map(function(i){
        return React.createElement('div', {key:i, style:{
          width:13, height:13, borderRadius:'50%',
          background: i < outs ? '#f87171' : 'transparent',
          border: '2px solid ' + (i < outs ? '#f87171' : '#475569'),
        }});
      })
    );

    // ダイヤモンドSVG
    var diamond = React.createElement('div', {style:{display:'flex',flexDirection:'column',alignItems:'center'}},
      React.createElement('svg', {viewBox:'0 0 160 150', width:160, height:145, style:{display:'block'}},
        React.createElement('path', {d:'M80,130 L20,70 L80,10 L140,70 Z', fill:'#1a2e1a'}),
        React.createElement('path', {d:'M80,118 L32,70 L80,22 L128,70 Z', fill:'none', stroke:'#2d4a2d', strokeWidth:1.5}),
        React.createElement('rect', {x:71,y:11, width:18,height:18, rx:2, transform:'rotate(45 80 20)', fill: b1 ? '#f59e0b' : '#1e3a5f', stroke: b1?'#fbbf24':'#334d66', strokeWidth:1.5}),
        React.createElement('rect', {x:119,y:59, width:18,height:18, rx:2, transform:'rotate(45 128 68)', fill: b0 ? '#f59e0b' : '#1e3a5f', stroke: b0?'#fbbf24':'#334d66', strokeWidth:1.5}),
        React.createElement('rect', {x:23,y:59, width:18,height:18, rx:2, transform:'rotate(45 32 68)', fill: b2 ? '#f59e0b' : '#1e3a5f', stroke: b2?'#fbbf24':'#334d66', strokeWidth:1.5}),
        React.createElement('polygon', {points:'80,128 87,121 80,114 73,121', fill:'#334155', stroke:'#475569', strokeWidth:1}),
        b1 ? React.createElement('text',{x:80,y:18,textAnchor:'middle',fontSize:7,fill:'#fff',fontWeight:'bold'}, b1.slice(0,3)) : null,
        b0 ? React.createElement('text',{x:128,y:66,textAnchor:'middle',fontSize:7,fill:'#fff',fontWeight:'bold'}, b0.slice(0,3)) : null,
        b2 ? React.createElement('text',{x:32,y:66,textAnchor:'middle',fontSize:7,fill:'#fff',fontWeight:'bold'}, b2.slice(0,3)) : null
      ),
      outDots
    );

    // スタイル
    var thS = {color:'#64748b',fontSize:11,padding:'4px 4px',textAlign:'center',borderBottom:'1px solid #1e3a5f',minWidth:20};
    var tdS = {fontSize:12,padding:'4px 4px',textAlign:'center',borderBottom:'1px solid #0f1e35',minWidth:20};
    var tdB = Object.assign({},tdS,{fontWeight:900,fontSize:15,color:'#fff'});

    return React.createElement('div', {style:{background:'#080f1e',height:'100vh',maxWidth:'100vw',color:'white',fontFamily:'sans-serif',display:'flex',flexDirection:'column',overflow:'hidden'}},

      // ヘッダー
      React.createElement('div', {style:{display:'flex',justifyContent:'space-between',alignItems:'center',padding:'8px 12px',borderBottom:'1px solid #1e3a5f',flexShrink:0}},
        React.createElement('div', {style:{fontSize:13,fontWeight:700,flex:1,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}, aName+' vs '+hName),
        React.createElement('div', {style:{fontSize:13,color:'#93c5fd',fontWeight:700,marginLeft:8,whiteSpace:'nowrap'}}, inning+'回'+topBot),
        React.createElement('button', {onClick:stopViewing, style:{marginLeft:10,background:'#1e3a5f',color:'#93c5fd',border:'none',borderRadius:6,padding:'5px 10px',fontSize:11,cursor:'pointer',flexShrink:0}}, '終了')
      ),

      // スコアボード
      React.createElement('div', {style:{overflowX:'auto',flexShrink:0,borderBottom:'1px solid #1e3a5f',WebkitOverflowScrolling:'touch'}},
        React.createElement('table', {style:{borderCollapse:'collapse',fontSize:11,minWidth:'max-content',width:'100%'}},
          React.createElement('thead', null,
            React.createElement('tr', null,
              React.createElement('th', {style:Object.assign({},thS,{textAlign:'left',paddingLeft:10,minWidth:72})},''),
              INNS.map(function(n){
                var active = n===inning;
                return React.createElement('th',{key:n,style:Object.assign({},thS,{color:active?'#7dd3fc':'#64748b',fontWeight:active?700:400,background:active?'#0a1e3d':'transparent'})},n);
              }),
              React.createElement('th',{style:Object.assign({},thS,{color:'#e2e8f0',fontWeight:700})},'計'),
              React.createElement('th',{style:Object.assign({},thS,{color:'#4ade80',fontWeight:700})},'H'),
              React.createElement('th',{style:Object.assign({},thS,{color:'#f87171',fontWeight:700})},'E')
            )
          ),
          React.createElement('tbody', null,
            [[aName,asc,awayScore,awayHits,awayErrs],[hName,hsc,homeScore,homeHits,homeErrs]].map(function(row,ri){
              var nm=row[0],sc=row[1],tot=row[2],hits=row[3],errs=row[4];
              return React.createElement('tr',{key:nm},
                React.createElement('td',{style:Object.assign({},tdS,{textAlign:'left',paddingLeft:10,fontWeight:700,fontSize:12,color:ri===0?'#fbbf24':'#7dd3fc'})},nm),
                INNS.map(function(n){
                  var v=sc[n]; var active=n===inning;
                  return React.createElement('td',{key:n,style:Object.assign({},tdS,{
                    color:v!==undefined&&v!==''&&v!==0?'#fff':'#475569',
                    background:active?'#0a1e3d':'transparent',
                    fontWeight:v>0?700:400
                  })},v!==undefined&&v!==''?v:'-');
                }),
                React.createElement('td',{style:tdB},tot),
                React.createElement('td',{style:Object.assign({},tdB,{color:'#4ade80'})},hits),
                React.createElement('td',{style:Object.assign({},tdB,{color:'#f87171'})},errs)
              );
            })
          )
        )
      ),

      // 中段：ダイヤモンド＋打者投手 (flex:1でのこりを占有)
      React.createElement('div', {style:{flex:1,display:'flex',flexDirection:'row',alignItems:'stretch',minHeight:0,borderBottom:'1px solid #1e3a5f'}},

        // 左：ダイヤモンド
        React.createElement('div', {style:{flex:'0 0 auto',display:'flex',alignItems:'center',justifyContent:'center',padding:'8px 8px',borderRight:'1px solid #1e3a5f'}},
          diamond
        ),

        // 右：打者・投手・前打者・ログ
        React.createElement('div', {style:{flex:1,display:'flex',flexDirection:'column',minWidth:0,overflow:'hidden'}},

          // 打者・投手
          React.createElement('div', {style:{display:'flex',borderBottom:'1px solid #1e3a5f',flexShrink:0}},
            React.createElement('div', {style:{flex:1,padding:'8px 10px',borderRight:'1px solid #1e3a5f'}},
              React.createElement('div', {style:{fontSize:9,color:'#64748b',marginBottom:2}}, '打者'),
              React.createElement('div', {style:{fontSize:14,fontWeight:700,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}, batStr)
            ),
            React.createElement('div', {style:{flex:1,padding:'8px 10px'}},
              React.createElement('div', {style:{fontSize:9,color:'#64748b',marginBottom:2}}, '投手'),
              React.createElement('div', {style:{fontSize:14,fontWeight:700,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}, pitStr)
            )
          ),

          // 前打者結果
          vlog.length > 0 ? React.createElement('div', {style:{padding:'6px 10px',borderBottom:'1px solid #1e3a5f',flexShrink:0,background:'#0a1628'}},
            React.createElement('div', {style:{fontSize:9,color:'#64748b',marginBottom:2}}, '前打者'),
            React.createElement('div', {style:{fontSize:11,color:'#cbd5e1',overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}, vlog[0].msg)
          ) : null,

          // プレイログ
          React.createElement('div', {style:{flex:1,overflowY:'auto',WebkitOverflowScrolling:'touch'}},
            React.createElement('div', {style:{fontSize:9,color:'#64748b',padding:'5px 10px 2px'}}, 'プレイログ'),
            vlog.slice(0,20).map(function(entry,i){
              return React.createElement('div', {key:i, style:{
                padding:'4px 10px',
                borderBottom:'1px solid #0f1e35',
                display:'flex',gap:6,alignItems:'flex-start'
              }},
                React.createElement('span', {style:{fontSize:9,color:'#475569',flexShrink:0,paddingTop:1}}, entry.ts||''),
                React.createElement('span', {style:{fontSize:11,color: i===0?'#e2e8f0':'#94a3b8',lineHeight:'1.4'}}, entry.msg||'')
              );
            })
          )
        )
      ),

      // フッター
      React.createElement('div', {style:{textAlign:'center',padding:'4px',color:'#1e3a5f',fontSize:10,flexShrink:0}}, '👁 '+syncGameId)
    );
  }

  return (
    React.createElement('div', { style: S.root,}
      , React.createElement('style', null, `
        @import url('https:
        *{box-sizing:border-box;margin:0;padding:0;}
        input::-webkit-outer-spin-button,input::-webkit-inner-spin-button{-webkit-appearance:none;}
