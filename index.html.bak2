function SpecialPlayModal({ teamLabel, bases, inning, onCommit, onCancel }) {
  const [selCode, setSelCode] = useState(null);

  // デフォルト: 全ランナーを1つ前進させた状態
  const autoAdvance = () => {
    const nb = [null, null, null];
    let scored = 0;
    // 3塁→本塁、2塁→3塁、1塁→2塁 の順で処理（上書き防止）
    for (let i = 2; i >= 0; i--) {
      if (bases[i]) {
        if (i === 2) { scored++; }
        else { nb[i+1] = bases[i]; }
      }
    }
    return { nb, scored };
  };

  const { nb: initBases, scored: initRuns } = autoAdvance();
  const [adjB, setAdjB] = useState(initBases);
  const [runs, setRuns] = useState(initRuns);

  const sp = SPECIAL_PLAYS.find(p=>p.code===selCode);

  // ランナーON/OFF: クリックした塁を切り替え
  // ON→OFF: null、OFF→ON: 元のランナー名（bases内を探す）か "●"
  const toggleBase = (i) => setAdjB(b=>{
    const n=[...b];
    if (n[i]) {
      n[i] = null;
    } else {
      // 元のbases内のランナー名で、adjBにまだ入っていないものを当てる
      const usedNames = n.filter(Boolean);
      const available = bases.filter(name => name && !usedNames.includes(name));
      n[i] = available[0] || "●";
    }
    return n;
  });
  

  return (
    React.createElement('div', { style: S.overlay, onClick: onCancel,}
      , React.createElement('div', { style: {...S.mBox, maxWidth:400}, onClick: e=>e.stopPropagation(),}
        , React.createElement('div', { style: {...S.mt, marginBottom:4},}, "⚡ 特殊プレー記録" )
        , React.createElement('div', { style: {fontSize:11,color:"#94a3b8",marginBottom:14},}
          , teamLabel, " / "  , inning, "回 — WP・PB・BKを記録します"
        )

        
        , React.createElement('div', { style: {display:"flex",flexDirection:"column",gap:8,marginBottom:16},}
          , SPECIAL_PLAYS.map(p=>(
            React.createElement('button', { key: p.code, onClick: ()=>setSelCode(c=>c===p.code?null:p.code),
              style: {
                background: selCode===p.code ? p.color+"33" : "#0a1628",
                border: `2px solid ${selCode===p.code ? p.color : "#1e3a5f"}`,
                borderRadius:10, padding:"10px 14px", cursor:"pointer",
                display:"flex", alignItems:"center", gap:12, textAlign:"left",
              },}
              , React.createElement('span', { style: {fontFamily:"'Bebas Neue',sans-serif",fontSize:22,
                color:selCode===p.code?p.color:"#94a3b8",minWidth:34},}, p.short)
              , React.createElement('div', null
                , React.createElement('div', { style: {fontSize:13,fontWeight:700,
                  color:selCode===p.code?p.color:"#e2e8f0"},}, p.label)
                , React.createElement('div', { style: {fontSize:11,color:"#64748b"},}, p.desc)
              )
            )
          ))
        )

        , selCode && (React.createElement(React.Fragment, null
          
          , React.createElement('div', { style: {marginBottom:12},}
            , React.createElement('div', { style: {fontSize:12,color:"#7db8e8",marginBottom:6,fontWeight:700},}, "進塁後のランナー位置（タップで切替）"

            )
            , React.createElement('div', { style: {display:"flex",justifyContent:"center"},}
              , (()=>{
                const V=100, cx=50, cy=52, arm=33, sq=11;
                const b2=[cx,cy-arm], b1=[cx+arm,cy], hm=[cx,cy+arm], b3=[cx-arm,cy];
                const pts=`${b2[0]},${b2[1]} ${b1[0]},${b1[1]} ${hm[0]},${hm[1]} ${b3[0]},${b3[1]}`;
                const bData=[[b1,0,"1B"],[b2,1,"2B"],[b3,2,"3B"]];
                return (
                  React.createElement('svg', { width: 100, height: 100, viewBox: `0 0 ${V} ${V}`, style: {display:"block",overflow:"visible"},}
                    , React.createElement('polygon', { points: pts, fill: "none", stroke: "#334155", strokeWidth: 2,})
                    , React.createElement('circle', { cx: hm[0], cy: hm[1], r: sq*0.85, fill: "#3b82f6",})
                    , bData.map(([[bx,by],idx,lbl])=>(
                      React.createElement('g', { key: idx, onClick: ()=>toggleBase(idx), style: {cursor:"pointer"},}
                        , React.createElement('rect', { x: bx-sq, y: by-sq, width: sq*2, height: sq*2, rx: 2,
                          fill: adjB[idx]?"#fbbf24":"#0d1f35",
                          stroke: adjB[idx]?"#fbbf24":"#334155", strokeWidth: 2,
                          transform: `rotate(45,${bx},${by})`,})
                        , React.createElement('circle', { cx: bx, cy: by, r: sq*1.6, fill: "transparent",})
                        , React.createElement('text', { x: bx, textAnchor: idx===0?"start":idx===2?"end":"middle",
                          dx: idx===0?sq+4:idx===2?-(sq+4):0,
                          dy: idx===1?-(sq+7):sq+9,
                          y: by, dominantBaseline: "middle",
                          fill: adjB[idx]?"#fbbf24":"#475569", fontSize: 9,
                          fontFamily: "sans-serif", style: {pointerEvents:"none"},}, lbl)
                      )
                    ))
                  )
                );
              })()
            )
          )

          
          , React.createElement('div', { style: {marginBottom:14},}
            , React.createElement('div', { style: {fontSize:12,color:"#7db8e8",marginBottom:8,fontWeight:700},}, "得点")
            , React.createElement('div', { style: {display:"flex",alignItems:"center",gap:14,justifyContent:"center"},}
              , React.createElement('button', { onClick: ()=>setRuns(r=>Math.max(0,r-1)),
                style: {width:34,height:34,borderRadius:"50%",background:"#1e3a5f",
                  border:"2px solid #2a6496",color:"#fff",fontSize:20,cursor:"pointer"},}, "−")
              , React.createElement('span', { style: {fontFamily:"'Bebas Neue',sans-serif",fontSize:48,
                color:runs>0?"#f87171":"#e2e8f0",lineHeight:1,minWidth:50,textAlign:"center"},}
                , runs
              )
              , React.createElement('button', { onClick: ()=>setRuns(r=>Math.min(9,r+1)),
                style: {width:34,height:34,borderRadius:"50%",background:"#1e3a5f",
                  border:"2px solid #2a6496",color:"#fff",fontSize:20,cursor:"pointer"},}, "＋")
            )
          )

          , React.createElement('button', { onClick: ()=>onCommit(selCode, adjB, runs),
            style: {...sBt(_optionalChain([sp, 'optionalAccess', _70 => _70.color])||"#7db8e8"),width:"100%",padding:"11px",fontSize:14,fontWeight:700,marginBottom:6},}, "✅ "
             , _optionalChain([sp, 'optionalAccess', _71 => _71.label]), "を記録する"
          )
        ))

        , React.createElement('button', { onClick: onCancel, style: S.cBtn,}, "キャンセル")
      )
    )
  );
}
function TeamLineupModal({ side, sideLabel, sideColor, teams, currentLineup, onApply, onCancel }) {
  const [selTeam,       setSelTeam]       = useState(teams.length===1 ? teams[0] : null);
  
  const [assignments,   setAssignments]   = useState({});
  const [activeSlot,    setActiveSlot]    = useState(null); 

  const members = _optionalChain([selTeam, 'optionalAccess', _72 => _72.members]) || [];
  const usedNames = new Set(Object.values(assignments));

  const assign = (slotIdx, name) => {
    setAssignments(a=>{
      const next = {...a};
      
      Object.keys(next).forEach(k=>{ if(next[k]===name) delete next[k]; });
      next[slotIdx] = name;
      return next;
    });
    setActiveSlot(null);
  };

  const clearSlot = (slotIdx) => {
    setAssignments(a=>{ const n={...a}; delete n[slotIdx]; return n; });
  };

  
  const [slotCount, setSlotCount] = useState(9);
  const addSlot    = () => setSlotCount(n=>Math.min(n+1, 15));
  const removeSlot = () => setSlotCount(n=>{
    const next = Math.max(1, n-1);
    
    setAssignments(a=>{ const na={...a}; delete na[next]; return na; });
    return next;
  });

  const handleApply = () => {
    if(!selTeam) return;
    onApply(selTeam, assignments, slotCount);
  };

  const lineupSlots = Array.from({length: slotCount}, (_,i)=>i);
  const assignedCount = Object.keys(assignments).length;

  return (
    React.createElement('div', { style: S.overlay, onClick: onCancel,}
      , React.createElement('div', { style: {...S.mBox,maxWidth:440,maxHeight:"92vh",overflowY:"auto",padding:16}, onClick: e=>e.stopPropagation(),}
        , React.createElement('div', { style: {...S.mt,marginBottom:4,borderLeft:`3px solid ${sideColor}`,paddingLeft:10},}, "👥 "
